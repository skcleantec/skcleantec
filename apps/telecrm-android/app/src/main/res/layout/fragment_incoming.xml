<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/telecrm_page_padding"
        android:paddingTop="@dimen/telecrm_page_padding"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/incoming_title"
            android:textAppearance="@style/TextAppearance.Telecrm.PageTitle" />
    </LinearLayout>

    <TextView
        android:id="@+id/permissionHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/telecrm_page_padding"
        android:paddingBottom="8dp"
        android:text="@string/incoming_permission_hint"
        android:textAppearance="@style/TextAppearance.Telecrm.Body"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/grantButton"
        style="@style/Widget.Telecrm.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/telecrm_page_padding"
        android:layout_marginBottom="8dp"
        android:text="@string/grant_call_log"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/incomingList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/telecrm_page_padding"
        android:paddingBottom="@dimen/telecrm_page_padding" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/detailPanel"
        style="@style/Widget.Telecrm.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/telecrm_page_padding"
        android:visibility="gone"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/telecrm_card_padding">

            <TextView
                android:id="@+id/detailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Telecrm.CardTitle" />

            <TextView
                android:id="@+id/detailBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textAppearance="@style/TextAppearance.Telecrm.Caption"
                android:textColor="@color/slate_600" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/sms_templates_title"
                android:textAppearance="@style/TextAppearance.Telecrm.SectionLabel" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/incomingSmsTemplateChips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/detailCall"
                    style="@style/Widget.Telecrm.Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="@string/call_button" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/detailSms"
                    style="@style/Widget.Telecrm.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="@string/sms_button" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
