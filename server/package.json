{
  "name": "skcleanteck-server",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node scripts/prepare-schema.js && prisma generate && tsc",
    "start": "node dist/index.js",
    "db:generate": "node scripts/prepare-schema.js && prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:orderforms": "tsx prisma/seed-orderform-samples.ts",
    "db:seed:schedule": "tsx prisma/seed-schedule-random.ts",
    "db:check-admin": "tsx scripts/check-admin.ts",
    "db:backfill-inquiry-numbers": "tsx scripts/backfill-inquiry-numbers.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
