{
  "name": "skcleanteck-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/prepare-schema.js && prisma generate && tsx watch src/index.ts",
    "build": "node scripts/prepare-schema.js && prisma generate && tsc",
    "start": "node dist/index.js",
    "db:generate": "node scripts/prepare-schema.js && prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:orderforms": "tsx prisma/seed-orderform-samples.ts",
    "db:seed:schedule": "tsx prisma/seed-schedule-random.ts",
    "db:seed:schedule:test-m3-m5": "tsx prisma/seed-schedule-mar-may-test.ts",
    "db:purge:schedule:test-m3-m5": "tsx prisma/seed-schedule-mar-may-test.ts --purge",
    "db:seed:map:test-20260416": "tsx prisma/seed-schedule-map-test-20260416.ts",
    "db:purge:map:test-20260416": "tsx prisma/seed-schedule-map-test-20260416.ts --purge",
    "deploy:seed-from-config": "tsx scripts/run-deploy-schedule-seed.ts",
    "deploy:ensure-tenant-admins": "tsx scripts/ensure-default-tenant-admins.ts",
    "deploy:ensure-platform-admin": "tsx scripts/ensure-platform-admin.ts",
    "db:seed:unassigned-month": "tsx prisma/seed-unassigned-month-test.ts",
    "db:purge:unassigned-month-test": "tsx prisma/seed-unassigned-month-test.ts --purge",
    "db:check-admin": "tsx scripts/check-admin.ts",
    "verify:multitenant:phase1": "tsx scripts/verify-multitenant-phase1.ts",
    "verify:multitenant:phase2": "tsx scripts/verify-multitenant-phase2.ts",
    "verify:multitenant:phase3": "tsx scripts/verify-multitenant-phase3.ts",
    "verify:multitenant:phase4": "tsx scripts/verify-multitenant-phase4.ts",
    "verify:multitenant:phase5": "tsx scripts/verify-multitenant-phase5.ts",
    "verify:multitenant:tenant-exchange": "tsx scripts/verify-multitenant-tenant-exchange.ts",
    "verify:review-payback:phase1": "tsx scripts/verify-review-payback-phase1.ts",
    "verify:review-payback:phase2-db": "tsx scripts/verify-review-payback-phase2-db.ts",
    "verify:review-payback:phase3": "tsx scripts/verify-review-payback-phase3.ts",
    "verify:multitenant:phase6": "tsx scripts/verify-multitenant-phase6.ts",
    "db:backfill-inquiry-numbers": "node scripts/run-backfill-inquiry-numbers.mjs",
    "db:backfill-seed-inquiries-created-by": "tsx scripts/backfill-seed-inquiries-created-by.ts",
    "db:backfill-inquiry-address-geo": "tsx scripts/backfill-inquiry-address-geo.ts",
    "db:migrate-cs-images": "tsx scripts/migrate-cs-images-to-cloudinary.ts",
    "db:purge:inquiries": "tsx scripts/purge-all-inquiries.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "html-to-docx": "^1.8.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.1",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.6.0"
  }
}
