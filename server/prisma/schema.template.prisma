generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "__DB_PROVIDER__"
  url      = env("DATABASE_URL")
}

/// 팀장 일반 정산 — 건당 고정(원) 또는 일반 서비스 금액(`service_total_amount` 등) 대비 만분율
enum TeamLeaderGeneralSettlementMode {
  FIXED_PER_JOB_WON
  PERCENT_OF_GENERAL_SERVICE_BPS
}

/// 팀장 월 지급 기록 구분 — 일반(건당) 정산 vs 추가결재 정산
enum TeamLeaderPayrollPaymentBucket {
  GENERAL_JOB_SETTLEMENT
  ADDITIONAL_RECEIPT_SETTLEMENT
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
}

/// 테넌트 간 DB 거래 파트너십 상태
enum TenantPartnershipStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

/// 파트너십 중지 주체 (플랫폼·참여 테넌트)
enum TenantPartnershipSuspendedBy {
  PLATFORM
  TENANT_LOW
  TENANT_HIGH
}

enum TenantInquiryShareDirection {
  LOW_TO_HIGH
  HIGH_TO_LOW
}

enum TenantInquiryShareSyncStatus {
  ACTIVE
  PAUSED
  REVOKED
}

enum TenantPartnerSettlementRole {
  SELLER
  BUYER
}

enum PlatformRole {
  SUPER_ADMIN
  SUPPORT
}

model Tenant {
  id          String       @id @default(uuid())
  slug        String       @unique @db.VarChar(48)
  name        String       @db.VarChar(128)
  status      TenantStatus @default(ACTIVE)
  plan        String       @default("premium") @db.VarChar(32)
  timezone    String       @default("Asia/Seoul") @db.VarChar(64)
  config      Json         @default("{}")
  createdAt   DateTime     @default(now()) @map("created_at")
  suspendedAt DateTime?    @map("suspended_at")

  users     User[]
  inquiries Inquiry[]
  features  TenantFeature[]
  orderForms OrderForm[]
  externalCompanies ExternalCompany[]
  adChannels AdChannel[]
  teams Team[]
  orderFollowups OrderFollowup[]
  reviewPaybackRequests ReviewPaybackRequest[]
  csReports CsReport[]
  messages Message[]
  assignments Assignment[]
  adWorkSessions AdWorkSession[]
  dailyInquiryCounters DailyInquiryCounter[]
  scheduleDayClosures ScheduleDayClosure[]
  scheduleDaySlotAdjustments ScheduleDaySlotToAdjustment[]
  scheduleDayLeaderSlots ScheduleDayLeaderSlot[]
  scheduleDayTeamMemberSlots ScheduleDayTeamMemberSlot[]
  teamCrewGroups TeamCrewGroup[]
  payrollAdminPersonalExpenses PayrollAdminPersonalExpense[]
  payrollAdminSharedExpenses PayrollAdminSharedExpense[]
  payrollIncomeDeposits PayrollIncomeDeposit[]
  payrollAccountLedgerManualEntries PayrollAccountLedgerManualEntry[]
  userCustomCalendars UserCustomCalendar[]
  eContractIssuerProfiles EContractIssuerProfile[]
  eContractFieldDefinitions EContractFieldDefinition[]
  eContractDefinitions EContractDefinition[]
  teamMembers TeamMember[]
  orderFormConfigs OrderFormConfig[]
  estimateConfigs EstimateConfig[]
  estimateOptions EstimateOption[]
  professionalSpecialtyOptions ProfessionalSpecialtyOption[]
  orderFormTemplates OrderFormTemplate[]
  orderFormTemplateFields OrderFormTemplateField[]
  operatingCompanies OperatingCompany[]
  userOperatingCompanies UserOperatingCompany[]
  partnershipsAsLow TenantPartnership[] @relation("TenantPartnershipLow")
  partnershipsAsHigh TenantPartnership[] @relation("TenantPartnershipHigh")
  partnershipsRequested TenantPartnership[] @relation("TenantPartnershipRequestedBy")
  tenantPartnerSettlementPayments TenantPartnerSettlementPayment[] @relation("TenantPartnerSettlementPayments")
  tenantPartnerSettlementResets TenantPartnerSettlementReset[] @relation("TenantPartnerSettlementResets")

  @@map("tenants")
}

/// 솔루션 가입 테넌트 간 DB 거래 파트너십 (Phase 1: 관계·동의만)
model TenantPartnership {
  id                  String                      @id @default(uuid())
  tenantLowId         String                      @map("tenant_low_id")
  tenantHighId        String                      @map("tenant_high_id")
  status              TenantPartnershipStatus     @default(PENDING)
  requestedByTenantId String                      @map("requested_by_tenant_id")
  lowAcceptedAt       DateTime?                   @map("low_accepted_at")
  highAcceptedAt      DateTime?                   @map("high_accepted_at")
  suspendedAt         DateTime?                   @map("suspended_at")
  suspendedBy         TenantPartnershipSuspendedBy? @map("suspended_by")
  memo                String?                     @db.Text
  createdAt           DateTime                    @default(now()) @map("created_at")
  updatedAt           DateTime                    @updatedAt @map("updated_at")

  tenantLow   Tenant @relation("TenantPartnershipLow", fields: [tenantLowId], references: [id], onDelete: Cascade)
  tenantHigh  Tenant @relation("TenantPartnershipHigh", fields: [tenantHighId], references: [id], onDelete: Cascade)
  requestedBy Tenant @relation("TenantPartnershipRequestedBy", fields: [requestedByTenantId], references: [id], onDelete: Restrict)
  inquiryShares TenantInquiryShare[]
  settlementPayments TenantPartnerSettlementPayment[]
  settlementResets TenantPartnerSettlementReset[]

  @@unique([tenantLowId, tenantHighId])
  @@index([tenantLowId, status])
  @@index([tenantHighId, status])
  @@map("tenant_partnerships")
}

/// 테넌트 간 접수(DB) 전달 링크 — 송신 원본 + 수신 mirror Inquiry 쌍
model TenantInquiryShare {
  id                          String                       @id @default(uuid())
  partnershipId               String                       @map("partnership_id")
  sourceTenantId              String                       @map("source_tenant_id")
  sourceInquiryId               String                       @unique @map("source_inquiry_id")
  targetTenantId              String                       @map("target_tenant_id")
  targetInquiryId               String                       @unique @map("target_inquiry_id")
  direction                   TenantInquiryShareDirection
  transferFee                 Int?                         @map("transfer_fee")
  syncStatus                  TenantInquiryShareSyncStatus @default(ACTIVE) @map("sync_status")
  sourceInquiryNumberSnapshot String?                      @map("source_inquiry_number_snapshot") @db.VarChar(24)
  sharedAt                    DateTime                     @map("shared_at")
  sharedByUserId              String?                      @map("shared_by_user_id")
  cancelFeeDirection          TenantInquiryShareDirection? @map("cancel_fee_direction")
  syncFieldMask               Json?                        @map("sync_field_mask")

  partnership   TenantPartnership @relation(fields: [partnershipId], references: [id], onDelete: Restrict)
  sourceInquiry Inquiry           @relation("ShareSourceInquiry", fields: [sourceInquiryId], references: [id], onDelete: Restrict)
  targetInquiry Inquiry           @relation("ShareTargetInquiry", fields: [targetInquiryId], references: [id], onDelete: Restrict)

  @@index([partnershipId])
  @@index([sourceTenantId, sharedAt])
  @@index([targetTenantId, sharedAt])
  @@map("tenant_inquiry_shares")
}

/// 테넌트 DB 거래 정산 — 수금(판매)·지급(구매) 1행
model TenantPartnerSettlementPayment {
  id              String                    @id @default(uuid())
  tenantId        String                    @map("tenant_id")
  partnerTenantId String                    @map("partner_tenant_id")
  partnershipId   String?                   @map("partnership_id")
  role            TenantPartnerSettlementRole
  amount          Int
  paidAt          DateTime                  @default(now()) @map("paid_at")
  memo            String?                   @db.Text
  actorId         String?                   @map("actor_id")

  tenant      Tenant             @relation("TenantPartnerSettlementPayments", fields: [tenantId], references: [id], onDelete: Cascade)
  partnership TenantPartnership? @relation(fields: [partnershipId], references: [id], onDelete: SetNull)
  actor       User?              @relation("TenantPartnerSettlementPaymentActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, role, partnerTenantId, paidAt])
  @@map("tenant_partner_settlement_payments")
}

/// 테넌트 DB 거래 정산 누적 초기화(파트너·역할별)
model TenantPartnerSettlementReset {
  id              String                    @id @default(uuid())
  tenantId        String                    @map("tenant_id")
  partnerTenantId String                    @map("partner_tenant_id")
  partnershipId   String?                   @map("partnership_id")
  role            TenantPartnerSettlementRole
  resetAt         DateTime                  @default(now()) @map("reset_at")
  actorId         String?                   @map("actor_id")

  tenant      Tenant             @relation("TenantPartnerSettlementResets", fields: [tenantId], references: [id], onDelete: Cascade)
  partnership TenantPartnership? @relation(fields: [partnershipId], references: [id], onDelete: SetNull)
  actor       User?              @relation("TenantPartnerSettlementResetActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, role, partnerTenantId, resetAt])
  @@map("tenant_partner_settlement_resets")
}

/// 플랜 대비 per-tenant 모듈 on/off 오버라이드
model TenantFeature {
  tenantId String  @map("tenant_id")
  moduleId String  @map("module_id") @db.VarChar(64)
  enabled  Boolean
  meta     Json    @default("{}")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, moduleId])
  @@map("tenant_features")
}

model PlatformUser {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String       @map("password_hash")
  name         String
  role         PlatformRole @default(SUPER_ADMIN)
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("platform_users")
}

/// 테넌트 내 영업 브랜드(운영 업체) — SK클린텍·타나클린 등. 타업체(ExternalCompany)와 별개.
model OperatingCompany {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String   @db.VarChar(128)
  /// 고객 URL `?brand=` 및 테넌트 내 식별용 영문 slug
  slug      String   @db.VarChar(48)
  isDefault Boolean  @default(false) @map("is_default")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  /// branding·orderForm·inquiry.numberPrefix 등
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userMemberships   UserOperatingCompany[]
  inquiries         Inquiry[]
  orderForms        OrderForm[]
  dailyCounters     DailyInquiryCounter[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive, sortOrder])
  @@map("operating_companies")
}

/// 마케터·팀장의 영업 업체 소속(다중). isPrimary 1개 권장.
model UserOperatingCompany {
  tenantId           String @map("tenant_id")
  userId             String @map("user_id")
  operatingCompanyId String @map("operating_company_id")
  isPrimary          Boolean @default(false) @map("is_primary")

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  operatingCompany OperatingCompany @relation(fields: [operatingCompanyId], references: [id], onDelete: Cascade)

  @@id([userId, operatingCompanyId])
  @@index([tenantId, userId])
  @@index([tenantId, operatingCompanyId])
  @@map("user_operating_companies")
}

/// 자사가 고객 정보를 넘기는 외부 협력 업체 (타업체)
model ExternalCompany {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  bizNumber String?  @map("biz_number") @db.VarChar(64)
  phone     String?  @db.VarChar(64)
  memo      String?  @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  partnerUsers User[]
  settlementResets ExternalCompanySettlementReset[]
  settlementPayments ExternalCompanySettlementPayment[]
  inquiriesCancelFeeFor Inquiry[] @relation("InquiryCancelFeeExternalCompany")
  payrollLedgerManualExpenseTargets PayrollAccountLedgerManualEntry[]

  @@index([tenantId, isActive])
  @@map("external_companies")
}

/// 타업체 정산 지급(부분/전체) 이력 1행
model ExternalCompanySettlementPayment {
  id                String   @id @default(uuid())
  externalCompanyId String   @map("external_company_id")
  amount            Int
  paidAt            DateTime @default(now()) @map("paid_at")
  memo              String?  @db.Text
  actorId           String?  @map("actor_id")

  externalCompany ExternalCompany @relation(fields: [externalCompanyId], references: [id], onDelete: Cascade)
  actor           User?           @relation("ExternalCompanySettlementPaymentActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([externalCompanyId, paidAt])
  @@map("external_company_settlement_payments")
}

/// 타업체 정산 완료 후 관리자가 수수료 누적을 초기화할 때마다 1행
model ExternalCompanySettlementReset {
  id                  String   @id @default(uuid())
  externalCompanyId   String   @map("external_company_id")
  resetAt             DateTime @default(now()) @map("reset_at")
  actorId             String?  @map("actor_id")

  externalCompany ExternalCompany @relation(fields: [externalCompanyId], references: [id], onDelete: Cascade)
  actor            User?          @relation("ExternalCompanySettlementResetActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([externalCompanyId, resetAt])
  @@map("external_company_settlement_resets")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String   @map("password_hash")
  name         String
  /// 크루 현장 일정 등 표시용 로마자 이름 (선택)
  nameEn       String?  @map("name_en") @db.VarChar(128)
  role         UserRole @default(TEAM_LEADER)
  phone        String?
  vehicleNumber String? @map("vehicle_number") @db.VarChar(64)
  isActive     Boolean  @default(true) @map("is_active")
  /// 테넌트 내 최고 관리자 (플랫폼 SUPER_ADMIN 과 별개)
  isTenantOwner Boolean @default(false) @map("is_tenant_owner")
  /// 타업체 로그인 계정(EXTERNAL_PARTNER)이 소속된 업체
  externalCompanyId String? @map("external_company_id")
  externalCompany   ExternalCompany? @relation(fields: [externalCompanyId], references: [id], onDelete: SetNull)
  /// 입사일(포함) — 해당일부터 스케줄·TO·배정 대상. null이면 제한 없음(기존 데이터 호환)
  hireDate     DateTime? @map("hire_date") @db.Date
  /// 퇴사일(미포함) — 해당일부터 근무·배정·드롭다운 제외. null이면 재직 중
  resignationDate DateTime? @map("resignation_date") @db.Date
  payrollMonthlySalary Int? @map("payroll_monthly_salary")
  payrollPayDay       Int? @map("payroll_pay_day")
  /// 팀장만 사용 — 일반 결재 정산: 건당 고정(원) 또는 일반 서비스 금액 대비 만분율
  teamLeaderGeneralSettlementMode TeamLeaderGeneralSettlementMode? @map("team_leader_general_settlement_mode")
  /// FIXED_PER_JOB_WON 이면 원/건, PERCENT_OF_GENERAL_SERVICE_BPS 이면 만분율(예 1500=15%)
  teamLeaderGeneralSettlementValue Int? @map("team_leader_general_settlement_value")
  /// 팀장만 사용 — 추가결재 정산 시 회사 몫 만분율(0~10000). null이면 UI에서 기본 50% 적용
  teamLeaderAdditionalReceiptCompanyShareBps Int? @map("team_leader_additional_receipt_company_share_bps")
  createdAt    DateTime @default(now()) @map("created_at")
  /// 팀장 본인 휴무일 등록·삭제 허용(관리자 사용자 목록에서 제어). 기본 true.
  allowSelfDayOffEdit Boolean @default(true) @map("allow_self_day_off_edit")
  /// 고객 대면용 사원증 이미지(Cloudinary). 팀장·마케터 — 관리자 업로드.
  staffIdCardPublicId String? @map("staff_id_card_public_id") @db.VarChar(512)
  staffIdCardUrl      String? @map("staff_id_card_url") @db.VarChar(2048)
  /// 접수 변경 이력 알림 — 이 사용자가 변경 이력을 마지막으로 확인한 시각. 이후 생성분이 미확인 알림.
  changeLogSeenAt     DateTime? @map("change_log_seen_at")

  assignmentsAssigned Assignment[] @relation("TeamLeaderAssignments")
  assignmentsGiven     Assignment[] @relation("AdminAssignments")
  sentMessages        Message[]    @relation("SentMessages")
  receivedMessages    Message[]    @relation("ReceivedMessages")
  dayOffs             UserDayOff[] @relation("UserDayOffs")
  orderFormsCreated   OrderForm[]  @relation("OrderFormCreatedBy")
  inquiriesCreated    Inquiry[]    @relation("InquiryCreatedBy")
  adWorkSessions      AdWorkSession[]
  /// 팀장당 1팀 (비로그인 팀원·휴무)
  team                Team? @relation("TeamLeaderTeam")
  scheduleDayLeaderSlots ScheduleDayLeaderSlot[]
  inquiryCleaningPhotosUploaded InquiryCleaningPhoto[] @relation("CleaningPhotoUploader")
  inquiryConsultationPhotosUploaded InquiryConsultationPhoto[] @relation("InquiryConsultationPhotoUploader")
  inquiryExtraChargesCreated    InquiryExtraCharge[]   @relation("InquiryExtraChargeCreatedBy")
  inquiryAdditionalReceiptsCreated InquiryAdditionalReceipt[] @relation("InquiryAdditionalReceiptCreatedBy")
  csReportsCompleted            CsReport[] @relation("CsReportCompletedBy")
  inquiryChangeLogsAsActor      InquiryChangeLog[]     @relation("InquiryChangeLogActor")
  teamLeaderWebPushSubscriptions TeamLeaderWebPushSubscription[]
  orderFollowupsCreated         OrderFollowup[]        @relation("OrderFollowupCreatedBy")
  orderFollowupsHandled         OrderFollowup[]        @relation("OrderFollowupHandledBy")
  reviewPaybacksHandled         ReviewPaybackRequest[] @relation("ReviewPaybackHandledBy")
  orderFollowupLogsAsActor      OrderFollowupLog[]     @relation("OrderFollowupLogActor")
  orderFormDeleteLogsAsActor    OrderFormDeleteLog[]   @relation("OrderFormDeleteLogActor")
  orderFormDeleteLogsAsCreator  OrderFormDeleteLog[]   @relation("OrderFormDeleteLogCreator")
  externalCompanySettlementResetsAsActor ExternalCompanySettlementReset[] @relation("ExternalCompanySettlementResetActor")
  externalCompanySettlementPaymentsAsActor ExternalCompanySettlementPayment[] @relation("ExternalCompanySettlementPaymentActor")
  tenantPartnerSettlementPaymentsAsActor TenantPartnerSettlementPayment[] @relation("TenantPartnerSettlementPaymentActor")
  tenantPartnerSettlementResetsAsActor TenantPartnerSettlementReset[] @relation("TenantPartnerSettlementResetActor")
  operatingCompanyMemberships UserOperatingCompany[]
  customCalendars               UserCustomCalendar[]   @relation("UserCustomCalendars")
  crewStaffNoticesSent          CrewStaffNotice[]     @relation("CrewStaffNoticeSender")
  teamMemberPayrollSettlementsAsActor TeamMemberPayrollSettlement[] @relation("TeamMemberPayrollSettlementActor")
  marketerPayrollSettlements           MarketerPayrollSettlement[]
  marketerPayrollSettlementsAsActor     MarketerPayrollSettlement[] @relation("MarketerPayrollSettlementActor")
  teamLeaderPayrollPayments           TeamLeaderPayrollPayment[]
  teamLeaderPayrollPaymentsAsActor    TeamLeaderPayrollPayment[] @relation("TeamLeaderPayrollPaymentActor")
  payrollAdminPersonalExpensesCreated PayrollAdminPersonalExpense[] @relation("PayrollAdminPersonalExpenseCreator")
  payrollAdminSharedExpensesCreated PayrollAdminSharedExpense[] @relation("PayrollAdminSharedExpenseCreator")
  payrollIncomeDepositsCreated PayrollIncomeDeposit[] @relation("PayrollIncomeDepositCreator")
  payrollAccountLedgerManualEntriesCreated PayrollAccountLedgerManualEntry[] @relation("PayrollAccountLedgerManualEntryCreator")
  payrollLedgerManualEntriesLinked PayrollAccountLedgerManualEntry[] @relation("PayrollLedgerManualLinkedUser")
  csReportsForwardedTo          CsReport[] @relation("CsReportForwardedTo")
  /// 관리자가 생성한 전자계약(팀장) 정의 — `modules/e-contract`
  eContractDefinitionsCreated  EContractDefinition[] @relation("EContractDefinitionCreator")
  /// 발행측(갑) 프로필 마지막 수정자 — `modules/e-contract`
  eContractIssuerProfilesUpdated EContractIssuerProfile[] @relation("EContractIssuerProfileUpdater")
  /// 전자계약 버전 게시자(관리자)
  eContractVersionsPublishedBy EContractVersion[]    @relation("EContractVersionPublisher")
  /// 팀장에게 발급·체결된 전자계약(수신측 사용자)
  eContractIssuancesAsTeamLeader EContractIssuance[] @relation("EContractIssuanceTeamLeader")

  @@unique([tenantId, email])
  @@index([tenantId, role, isActive])
  @@map("users")
}

/// 팀장 급여표 — 귀속 월별 수시 지급 내역(관리자 기록). 고정 급여일 없이 여러 차례 입금 가능.
model TeamLeaderPayrollPayment {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  monthKey  String   @map("month_key") @db.VarChar(7)
  amount    Int
  paidOn    DateTime @map("paid_on") @db.Date
  memo      String?  @db.Text
  actorId   String?  @map("actor_id")
  createdAt DateTime @default(now()) @map("created_at")
  settlementBucket TeamLeaderPayrollPaymentBucket @default(GENERAL_JOB_SETTLEMENT) @map("settlement_bucket")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("TeamLeaderPayrollPaymentActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, monthKey])
  @@index([monthKey])
  @@map("team_leader_payroll_payments")
}

/// 팀장/타업체 계정 브라우저 Web Push 구독 (엔드포인트당 1행)
model TeamLeaderWebPushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique @db.Text
  p256dh    String   @map("p256dh") @db.Text
  auth      String   @db.Text
  userAgent String?  @map("user_agent") @db.VarChar(512)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("team_leader_web_push_subscriptions")
}

/// 팀장당 1팀 (팀원은 로그인 없음, 마스터·휴무만 관리)
model Team {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamLeaderId String   @unique @map("team_leader_id")
  memo         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  teamLeader User         @relation("TeamLeaderTeam", fields: [teamLeaderId], references: [id], onDelete: Cascade)
  members    TeamMember[]

  @@index([tenantId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// null이면 팀장 소속 없이 전사 풀 팀원
  teamId    String?  @map("team_id")
  name      String
  nameTh    String?  @map("name_th") @db.VarChar(128)
  phone     String?
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  /// 입사일(포함) — 해당일부터 스케줄·배정 대상. null이면 제한 없음
  hireDate     DateTime? @map("hire_date") @db.Date
  /// 퇴사일(미포함) — 해당일부터 근무·배정 제외. null이면 재직 중
  resignationDate DateTime? @map("resignation_date") @db.Date
  /// 매월 급여 지급일(1~31). null이면 미설정 — 팀원 월급 정산(근무일 수)용
  monthlyPayDay   Int? @map("monthly_pay_day")
  /// 1일 급여(일당, 원). null이면 미설정 — 정산 시 근무일 수×일당 계산에 사용(같은 날 여러 현장도 1일로 집계)
  payAmountPerJob Int? @map("pay_amount_per_job")
  /// 고객 대면용 사원증 이미지(Cloudinary). 현장 팀원 — 관리자 업로드.
  staffIdCardPublicId String? @map("staff_id_card_public_id") @db.VarChar(512)
  staffIdCardUrl      String? @map("staff_id_card_url") @db.VarChar(2048)
  createdAt DateTime @default(now()) @map("created_at")

  team    Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  dayOffs TeamMemberDayOff[]
  scheduleDaySlots ScheduleDayTeamMemberSlot[]
  crewGroupMembers  TeamCrewGroupMember[]
  crewGroupDayRoster TeamCrewGroupDayRoster[]
  crewGroupExpenses TeamCrewGroupExpense[]
  payrollMonthAdjusts TeamMemberPayrollMonthAdjust[]
  payrollSettlements TeamMemberPayrollSettlement[]
  payrollLedgerManualExpenseTargets PayrollAccountLedgerManualEntry[]

  @@index([tenantId, isActive])
  @@map("team_members")
}

/// 현장 팀원 급여 정산 완료 (귀속 월당 1건 — 확정 지급액 스냅샷)
model TeamMemberPayrollSettlement {
  id           String   @id @default(uuid())
  teamMemberId String   @map("team_member_id")
  monthKey     String   @map("month_key") @db.VarChar(7)
  amount       Int
  settledAt    DateTime @default(now()) @map("settled_at")
  actorId      String?  @map("actor_id")

  teamMember TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  actor      User?      @relation("TeamMemberPayrollSettlementActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@unique([teamMemberId, monthKey])
  @@index([teamMemberId, settledAt(sort: Desc)])
  @@map("team_member_payroll_settlements")
}

/// 마케터 급여 정산 완료 (귀속 월당 1건 — 부분 지급 시 미정산액은 다음 달 합산)
model MarketerPayrollSettlement {
