  extraWorkDays  Int      @default(0) @map("extra_work_days")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  teamMember TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@unique([teamMemberId, monthKey])
  @@index([monthKey])
  @@map("team_member_payroll_month_adjusts")
}

/// 태국인 팀원 등 공유 로그인으로 같은 화면을 보는 크루 그룹(팀원 관리에서 생성·설정)
model TeamCrewGroup {
  id     String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name   String
  /// 공유 로그인 아이디(테넌트 내 고유)
  loginId String @map("login_id") @db.VarChar(64)
  passwordHash String @map("password_hash")
  phone   String? @db.VarChar(32)
  /// true: 스케줄 집계·접수 팀원 선택 시 그룹장이 해당일 지정한 명단만 사용. false: 그룹 소속 활성 팀원 전원
  useDailyRosterOnly Boolean @default(false) @map("use_daily_roster_only")
  /// 민감 설정 시 별도 확인용 비밀번호(공유 로그인 비번과 별개). null이면 미설정
  settingsPasswordHash String? @map("settings_password_hash")
  isActive Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members   TeamCrewGroupMember[]
  dayRoster TeamCrewGroupDayRoster[]
  staffNotices CrewStaffNotice[]
  expenses  TeamCrewGroupExpense[]

  @@unique([tenantId, loginId])
  @@index([tenantId, isActive])
  @@map("team_crew_groups")
}

/// 운영(관리자·마케터)이 공지 시 「크루」 수신을 선택한 경우 — 공유 로그인(팀 크루 그룹)이 조회
model CrewStaffNotice {
  id          String   @id @default(uuid())
  batchId     String   @map("batch_id") @db.VarChar(64)
  senderId    String   @map("sender_id")
  crewGroupId String   @map("crew_group_id")
  content     String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  sender User          @relation("CrewStaffNoticeSender", fields: [senderId], references: [id], onDelete: Cascade)
  group  TeamCrewGroup @relation(fields: [crewGroupId], references: [id], onDelete: Cascade)

  @@index([crewGroupId, createdAt(sort: Desc)])
  @@map("crew_staff_notices")
}

model TeamCrewGroupMember {
  id            String   @id @default(uuid())
  groupId       String   @map("group_id")
  teamMemberId  String   @map("team_member_id")
  isGroupLeader Boolean  @default(false) @map("is_group_leader")
  createdAt     DateTime @default(now()) @map("created_at")

  group      TeamCrewGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teamMember TeamMember    @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@unique([groupId, teamMemberId])
  @@index([teamMemberId])
  @@map("team_crew_group_members")
}

/// 그룹장이 날짜별로 「이날 일할 수 있는」 팀원 명단
model TeamCrewGroupDayRoster {
  id           String   @id @default(uuid())
  groupId      String   @map("group_id")
  date         DateTime @db.Date
  teamMemberId String   @map("team_member_id")
  createdAt    DateTime @default(now()) @map("created_at")

  group      TeamCrewGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teamMember TeamMember    @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@unique([groupId, date, teamMemberId])
  @@index([groupId, date])
  @@map("team_crew_group_day_roster")
}

/// 크루 그룹장이 등록하는 팀원별 월별 지출(영수증 첨부 가능)
model TeamCrewGroupExpense {
  id           String   @id @default(uuid())
  crewGroupId  String   @map("crew_group_id")
  teamMemberId String   @map("team_member_id")
  /// 귀속 월 YYYY-MM (KST 달력 기준과 동일하게 클라이언트에서 전달)
  monthKey     String   @map("month_key") @db.VarChar(7)
  amount       Int
  memo         String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  group       TeamCrewGroup                     @relation(fields: [crewGroupId], references: [id], onDelete: Cascade)
  teamMember  TeamMember                        @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  attachments TeamCrewGroupExpenseAttachment[]

  @@index([crewGroupId, monthKey])
  @@index([teamMemberId, monthKey])
  @@map("team_crew_group_expenses")
}

model TeamCrewGroupExpenseAttachment {
  id                 String @id @default(uuid())
  expenseId          String @map("expense_id")
  cloudinaryPublicId String @map("cloudinary_public_id") @db.VarChar(512)
  secureUrl          String @map("secure_url") @db.VarChar(2048)
  width              Int?
  height             Int?
  createdAt          DateTime @default(now()) @map("created_at")

  expense TeamCrewGroupExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@map("team_crew_group_expense_attachments")
}

/// 급여표 「지출」탭 — 관리자가 귀속 월별로 기록하는 개인·업무 지출(참고용, 인건비 산정과 무관)
model PayrollAdminPersonalExpense {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  monthKey    String   @map("month_key") @db.VarChar(7)
  amount      Int
  memo        String?  @db.Text
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User @relation("PayrollAdminPersonalExpenseCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, monthKey, createdAt(sort: Desc)])
  @@map("payroll_admin_personal_expenses")
}

/// 급여표 「정산」탭 — 관리자가 귀속 월별로 기록하는 공용·부서 지출(참고용, 인건비 산정과 무관)
model PayrollAdminSharedExpense {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  monthKey    String   @map("month_key") @db.VarChar(7)
  amount      Int
  memo        String?  @db.Text
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User @relation("PayrollAdminSharedExpenseCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, monthKey, createdAt(sort: Desc)])
  @@map("payroll_admin_shared_expenses")
}

/// 급여표 「정산」탭 수입 영역 — 귀속 월별 실제 입금 기록(참고용, 접수 매출 자동 집계와 별개)
model PayrollIncomeDeposit {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  monthKey     String   @map("month_key") @db.VarChar(7)
  depositedOn  DateTime @map("deposited_on") @db.Date
  amount       Int
  memo         String?  @db.Text
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User @relation("PayrollIncomeDepositCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, monthKey, depositedOn(sort: Desc)])
  @@map("payroll_income_deposits")
}

enum PayrollAccountLedgerManualDirection {
  IN
  OUT
}

/// 수기 장부 지출을 급여 대상(현장·팀장 등)과 연결할 때 구분 — 확장용 enum
enum PayrollLedgerManualPayrollLinkKind {
  NONE
  POOL_MEMBER
  TEAM_LEADER
  MARKETER
  EXTERNAL_COMPANY
}

/// 월정산표 「계정 수입·지출 표」— 관리자 수기 수입·지출(현금성 장부 반영)
model PayrollAccountLedgerManualEntry {
  id           String                          @id @default(uuid())
  tenantId     String                          @map("tenant_id")
  tenant       Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  monthKey     String                          @map("month_key") @db.VarChar(7)
  direction    PayrollAccountLedgerManualDirection @map("direction")
  occurredOn   DateTime                        @map("occurred_on") @db.Date
  accountLabel String                          @map("account_label") @db.VarChar(128)
  amount       Int
  memo         String?                         @db.Text
  /// 지출을 특정 급여 대상 실지급 예상에서 차감할 때(수입은 NONE 고정)
  payrollLinkKind PayrollLedgerManualPayrollLinkKind @default(NONE) @map("payroll_link_kind")
  linkTeamMemberId String?                        @map("link_team_member_id")
  linkUserId       String?                        @map("link_user_id")
  linkExternalCompanyId String?                   @map("link_external_company_id")
  createdById  String                          @map("created_by_id")
  createdAt    DateTime                        @default(now()) @map("created_at")
  updatedAt    DateTime                        @updatedAt @map("updated_at")

  createdBy User @relation("PayrollAccountLedgerManualEntryCreator", fields: [createdById], references: [id], onDelete: Restrict)
  linkTeamMember TeamMember? @relation(fields: [linkTeamMemberId], references: [id], onDelete: Restrict)
  linkUser User? @relation("PayrollLedgerManualLinkedUser", fields: [linkUserId], references: [id], onDelete: Restrict)
  linkExternalCompany ExternalCompany? @relation(fields: [linkExternalCompanyId], references: [id], onDelete: Restrict)

  @@index([tenantId, monthKey, payrollLinkKind, linkTeamMemberId], map: "pld_manual_month_pool_idx")
  @@index([tenantId, monthKey, payrollLinkKind, linkUserId], map: "pld_manual_month_user_idx")
  @@index([tenantId, monthKey, occurredOn(sort: Asc), createdAt(sort: Asc)])
  @@map("payroll_account_ledger_manual_entries")
}

model TeamMemberDayOff {
  id           String   @id @default(uuid())
  teamMemberId String   @map("team_member_id")
  date         DateTime @db.Date @map("date")
  createdAt    DateTime @default(now()) @map("created_at")

  teamMember TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@unique([teamMemberId, date])
  @@map("team_member_day_offs")
}

model UserDayOff {
  id            String   @id @default(uuid())
  teamLeaderId  String   @map("team_leader_id")
  date          DateTime @db.Date @map("date")
  createdAt     DateTime @default(now()) @map("created_at")

  teamLeader User @relation("UserDayOffs", fields: [teamLeaderId], references: [id], onDelete: Cascade)

  @@unique([teamLeaderId, date])
  @@map("user_day_offs")
}

enum UserRole {
  ADMIN
  TEAM_LEADER
  MARKETER
  /// 일반 사무직 — 급여표·정산 인건비만(관리 업무 로그인 없음)
  OFFICE_STAFF
  /// 타업체 담당자 — 팀장과 동일하게 /team 로그인·담당 접수 조회
  EXTERNAL_PARTNER
}

/// KST 일자별 접수 순번 (YYMMDD + 4자리 = 10자리 `inquiry_number` 발급용, 영업 업체별)
model DailyInquiryCounter {
  tenantId           String @map("tenant_id")
  tenant             Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  operatingCompanyId String @map("operating_company_id")
  operatingCompany   OperatingCompany @relation(fields: [operatingCompanyId], references: [id], onDelete: Cascade)
  dateKey            String @map("date_key") @db.VarChar(8)
  lastSeq            Int    @map("last_seq")

  @@id([tenantId, operatingCompanyId, dateKey])
  @@map("daily_inquiry_counters")
}

/// 마케터·관리자 내부용 고객 등급(접수 단위) — 고객·외부 노출 금지
enum InternalCustomerTone {
  GOOD
  NORMAL
  BAD
}

model Inquiry {
  id              String       @id @default(uuid())
  tenantId        String       @map("tenant_id")
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  operatingCompanyId String    @map("operating_company_id")
  operatingCompany   OperatingCompany @relation(fields: [operatingCompanyId], references: [id], onDelete: Restrict)
  /// 고객·검색용 접수번호 (KST YYMMDD + 4자리 + 선택 접두)
  inquiryNumber   String?      @map("inquiry_number") @db.VarChar(24)
  customerName    String       @map("customer_name")
  /// 선택 입력: 고객 호칭·별칭(예: 어머님, 관리실)
  nickname        String?      @map("nickname")
  customerPhone   String       @map("customer_phone")
  customerPhone2  String?      @map("customer_phone_2")
  address         String
  addressDetail   String?      @map("address_detail")
  /// 도로명 등 지오코딩 입력과 동일한 문자열(변경 시에만 카카오·Nominatim 재조회)
  addressGeoQuery String?      @map("address_geo_query") @db.VarChar(512)
  addressGeoLat   Float?       @map("address_geo_lat")
  addressGeoLng   Float?       @map("address_geo_lng")
  areaPyeong      Float?       @map("area_pyeong")
  areaBasis       String?      @map("area_basis")
  /// 전용면적 기준 시 고객·관리자 참고용 제곱미터(㎡). 평수와 별도.
  exclusiveAreaSqm Float?      @map("exclusive_area_sqm")
  propertyType    String?      @map("property_type")
  /// 발주서·접수 편집에서 원룸 체크 시 true — 목록·스케줄 표시용
  isOneRoom       Boolean      @default(false) @map("is_one_room")
  roomCount       Int?         @map("room_count")
  bathroomCount   Int?         @map("bathroom_count")
  balconyCount    Int?         @map("balcony_count")
  preferredDate       DateTime? @map("preferred_date")
  preferredTime       String?   @map("preferred_time")
  /// 사이청소만: 미확정 null, 확정 시 오전/오후 중 하나(해당 슬롯 1건 소모)
  betweenScheduleSlot String?   @map("between_schedule_slot")
  preferredTimeDetail String?   @map("preferred_time_detail")
  callAttempt     Int?         @map("call_attempt")
  memo            String?
  claimMemo       String?       @map("claim_memo")
  status          InquiryStatus @default(RECEIVED)
  source          String?      @default("전화")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @default(now()) @updatedAt @map("updated_at")
  /// 팀장이 지정한 크루 현장 미팅 시각(KST, "HH:mm"). 오전 희망 접수에만 노출 등에 사용
  crewMeetingTime   String?       @map("crew_meeting_time") @db.VarChar(5)
  /// 팀장이 미팅 시각을 저장·변경한 시각(크루 UI «수정됨» 배지용)
  crewMeetingTimeUpdatedAt DateTime? @map("crew_meeting_time_updated_at")
  /// 팀장이 고객에게 전화로 일정 안내(해피콜) 완료 시각 — 미입력이면 미완료
  happyCallCompletedAt DateTime? @map("happy_call_completed_at")

  assignments   Assignment[]
  extraCharges  InquiryExtraCharge[]
  additionalReceipts InquiryAdditionalReceipt[]
  buildingType String?       @map("building_type")
  moveInDate   DateTime?     @map("move_in_date")
  /// 거주 외 선택 시 이사일 미입력 대신 「미정」 표시(발주서·접수 동기화)
  moveInDateUndecided Boolean @default(false) @map("move_in_date_undecided")
  specialNotes String?       @map("special_notes")
  kitchenCount Int?          @map("kitchen_count")
  /// 정산·스케줄용 금액(발주서 연동 시 자동 입력, 개별 접수는 관리자 입력)
  serviceTotalAmount   Int? @map("service_total_amount")
  serviceDepositAmount Int? @map("service_deposit_amount")
  serviceBalanceAmount Int? @map("service_balance_amount")
  /// 현장 투입 비로그인 팀원 인원 수(관리자 입력)
  crewMemberCount Int?       @map("crew_member_count")
  /// 팀원 누구 투입 등 수기 메모(예: 김,태)
  crewMemberNote  String?    @map("crew_member_note")
  /// 스케줄 목록(이름·접수번호 옆)에만 쓰는 짧은 메모 — 특이사항·발주서 메모와 별개
  scheduleMemo    String?    @map("schedule_memo")
  /// 상담·참고 사진과 함께 쓰는 마케터 메모 — 담당 팀장·타업체·마케터 공유
  consultationMemo String?   @map("consultation_memo") @db.Text
  /// 타업체 담당 시 받는 수수료(원). 미입력 시 null
  externalTransferFee Int?   @map("external_transfer_fee")
  /// 취소 후에도 타업체 수수료 역분개를 위해 취소 시점 업체 id 보관
  cancelFeeExternalCompanyId String?          @map("cancel_fee_external_company_id")
  cancelFeeExternalCompany   ExternalCompany? @relation("InquiryCancelFeeExternalCompany", fields: [cancelFeeExternalCompanyId], references: [id], onDelete: SetNull)
  orderFormId  String?       @map("order_form_id")
  /// 접수 등록자(마케터 등). 발주서 제출 시 발주서 생성 마케터 기준.
  createdById  String?       @map("created_by_id")
  /// 내부 고객 등급(😊/😐/😠) — 마케터·관리자만 조회·수정
  internalCustomerTone InternalCustomerTone @default(NORMAL) @map("internal_customer_tone")
  /// 전문 시공 옵션 id 목록(JSON 배열 문자열)
  professionalOptionIds Json? @map("professional_option_ids")

  orderForm   OrderForm?          @relation(fields: [orderFormId], references: [id])
  createdBy   User?               @relation("InquiryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  changeLogs  InquiryChangeLog[]
  cleaningPhotos InquiryCleaningPhoto[]
  consultationPhotos InquiryConsultationPhoto[]
  csReports      CsReport[]
  orderFollowups OrderFollowup[]
  reviewPaybackRequests ReviewPaybackRequest[]
  tenantShareAsSource TenantInquiryShare? @relation("ShareSourceInquiry")
  tenantShareAsTarget TenantInquiryShare? @relation("ShareTargetInquiry")

  @@index([createdAt])
  @@index([preferredDate])
  @@index([status, createdAt])
  @@index([createdById])
  @@index([tenantId, createdAt])
  @@index([tenantId, operatingCompanyId, createdAt])
  @@unique([tenantId, inquiryNumber])
  @@map("inquiries")
}

enum CleaningPhotoPhase {
  BEFORE
  AFTER
  /// 접수 목록 등에서 C/S(클레임) 등록 시 첨부 — 청소 전·후와 구분
  CLAIM
}

/// 추가결재 수금 경로 — 정산(일당 가산·차감) 방식이 다름
enum AdditionalReceiptSettlementChannel {
  /// 회사 계좌 입금 — 팀장 지급액에 본인 몫만큼 가산
  COMPANY_DEPOSIT
  /// 현장에서 팀장이 직접 수금 — 일당에서 회사 몫만큼 차감
  FIELD_RECEIVED
}

/// 팀장·관리자·마케터가 현장에서 발생한 추가 청구·할인 항목과 금액을 기록 (레거시).
/// `amount`는 원화 정수, 음수면 할인. 총 결제받을 금액 = balance + sum(amount).
/// 신규 「추가결재」(별도 정산)는 `InquiryAdditionalReceipt` 사용.
model InquiryExtraCharge {
  id          String   @id @default(uuid())
  inquiryId   String   @map("inquiry_id")
  description String   @db.VarChar(120)
  amount      Int
  sortOrder   Int      @default(0) @map("sort_order")
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  inquiry   Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("InquiryExtraChargeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([inquiryId, sortOrder])
  @@map("inquiry_extra_charges")
}

/// 「추가결재」— 일반 서비스 금액(`service_*`)과 분리 저장. 정산 시 팀장별 추가결재 회사 몫 만분율로 별도 계산.
model InquiryAdditionalReceipt {
  id          String   @id @default(uuid())
  inquiryId   String   @map("inquiry_id")
  description String   @db.VarChar(120)
  /// 원화 정수, 1원 이상
  amount      Int
  /// 회사입금 vs 현장수금 — 급여 정산 가산·차감 구분
  settlementChannel AdditionalReceiptSettlementChannel @default(COMPANY_DEPOSIT) @map("settlement_channel")
  sortOrder   Int      @default(0) @map("sort_order")
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  inquiry   Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("InquiryAdditionalReceiptCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([inquiryId, sortOrder])
  @@map("inquiry_additional_receipts")
}

/// 현장 청소 전·후 사진 (Cloudinary)
model InquiryCleaningPhoto {
  id                 String   @id @default(uuid())
  inquiryId          String   @map("inquiry_id")
  phase              CleaningPhotoPhase @map("phase")
  cloudinaryPublicId String   @map("cloudinary_public_id") @db.VarChar(512)
  secureUrl          String   @map("secure_url") @db.VarChar(1024)
  width              Int?
  height             Int?
  uploadedById       String   @map("uploaded_by_id")
  createdAt          DateTime @default(now()) @map("created_at")

  inquiry    Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("CleaningPhotoUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([inquiryId, phase, createdAt])
  @@map("inquiry_cleaning_photos")
}

/// 마케터·관리자가 상담 중 받은 참고 사진 (Cloudinary) — 담당 팀장·타업체·마케터 조회
model InquiryConsultationPhoto {
  id                 String   @id @default(uuid())
  inquiryId          String   @map("inquiry_id")
  cloudinaryPublicId String   @map("cloudinary_public_id") @db.VarChar(512)
  secureUrl          String   @map("secure_url") @db.VarChar(1024)
  width              Int?
  height             Int?
  uploadedById       String   @map("uploaded_by_id")
  createdAt          DateTime @default(now()) @map("created_at")

  inquiry    Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("InquiryConsultationPhotoUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([inquiryId, createdAt])
  @@map("inquiry_consultation_photos")
}

enum ScheduleClosureScope {
  FULL
  MORNING
  AFTERNOON
}

/// 관리자 수동 일정 마감(범위별 잔여 슬롯·TO 조정)
model ScheduleDayClosure {
  id        String               @id @default(uuid())
  tenantId  String               @map("tenant_id")
  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date      DateTime             @db.Date @map("date")
  scope     ScheduleClosureScope @default(FULL) @map("scope")
  createdAt DateTime             @default(now()) @map("created_at")

  @@unique([tenantId, date])
  @@map("schedule_day_closures")
}

/// 스케줄표·캘린더에 표시되는 오전·오후 잔여 슬롯(TO) 숫자 보정(가산)
model ScheduleDaySlotToAdjustment {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date           DateTime @db.Date @map("date")
  morningDelta   Int      @default(0) @map("morning_delta")
  afternoonDelta Int      @default(0) @map("afternoon_delta")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, date])
  @@map("schedule_day_slot_to_adjustments")
}

/// 일자별 팀장 오전·오후 가용(관리자 수동, 없으면 휴무일 기준)
model ScheduleDayLeaderSlot {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date               DateTime @db.Date @map("date")
  teamLeaderId       String   @map("team_leader_id")
  morningAvailable   Boolean  @map("morning_available")
  afternoonAvailable Boolean  @map("afternoon_available")
  note               String?  @map("note")

  teamLeader User @relation(fields: [teamLeaderId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date, teamLeaderId])
  @@map("schedule_day_leader_slots")
}

/// 일자별 팀원 가용(관리자 수동, 없으면 휴무일 기준)
model ScheduleDayTeamMemberSlot {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date @map("date")
  teamMemberId String   @map("team_member_id")
  available    Boolean
  note         String?  @map("note")

  teamMember TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date, teamMemberId])
  @@map("schedule_day_team_member_slots")
}

/// 발주서·접수에서 선택하는 전문 시공 옵션 (관리자 설정)
/// - 루트+`isGroup`: 대분류(섹션 제목, 직접 선택 불가). 하위는 `parentId`로 연결
/// - 루트+!`isGroup`+자식 없음: 기존 단일 옵션과 동일(고객이 직접 체크)
/// - `parentId`가 있으면 상세 옵션이며 `priceAmount`로 가격(원) 설정 가능
model ProfessionalSpecialtyOption {
  tenantId  String  @map("tenant_id")
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  id        String
  parentId  String? @map("parent_id")
  parent    ProfessionalSpecialtyOption?  @relation("ProfSpecTree", fields: [tenantId, parentId], references: [tenantId, id], onDelete: Cascade)
  children  ProfessionalSpecialtyOption[]  @relation("ProfSpecTree")
  /// 루트(`parentId` null)에서만 사용. true면 대분류(섹션), 고객은 하위 항목만 선택
  isGroup   Boolean @default(false) @map("is_group")
  label     String
  priceHint String? @map("price_hint")
  /// 상세 옵션(하위) 또는 단독 루트의 금액(원). 대분류 루트는 null
  priceAmount Int?  @map("price_amount")
  emoji     String?
  color     String?
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@id([tenantId, id])
  @@index([tenantId, parentId, sortOrder])
  @@map("professional_specialty_options")
}

/// 관리자 수정 시 날짜·금액 등 변경 이력 (접수 목록·스케줄에서 조회)
model InquiryChangeLog {
  id           String   @id @default(uuid())
  inquiryId    String?  @map("inquiry_id")
  customerName String   @default("") @map("customer_name")
  createdAt    DateTime @default(now()) @map("created_at")
  actorId      String?  @map("actor_id")
  lines        Json

  inquiry Inquiry? @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  actor   User?    @relation("InquiryChangeLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([inquiryId, createdAt(sort: Desc)])
  @@map("inquiry_change_logs")
}

model EstimateConfig {
  id             String   @id @default(uuid())
  tenantId       String   @unique @map("tenant_id")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pricePerPyeong Int      @map("price_per_pyeong")
  depositAmount  Int      @default(20000) @map("deposit_amount")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("estimate_config")
}

model EstimateOption {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  extraAmount Int      @map("extra_amount")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, isActive])
  @@map("estimate_options")
}

model OrderFormConfig {
  id                  String   @id @default(uuid())
  tenantId            String   @unique @map("tenant_id")
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  formTitle           String   @default("입주청소 발주서") @map("form_title")
  priceLabel          String?  @default("(특가)") @map("price_label")
  reviewEventText     String?  @map("review_event_text")
  footerNotice1       String?  @map("footer_notice_1")
  footerNotice2       String?  @map("footer_notice_2")
  infoContent         String?  @map("info_content")
  infoLinkText        String?  @map("info_link_text")
  submitSuccessTitle  String?  @map("submit_success_title")
  submitSuccessBody   String?  @map("submit_success_body")
  /// 고객 발주서 — 시간대 선택 전 확인 모달 제목
  timeSlotAckTitle       String? @map("time_slot_ack_title")
  /// 고객 발주서 — 시간대 안내 본문(여러 줄 가능)
  timeSlotAckBody        String? @map("time_slot_ack_body") @db.Text
  /// 고객 발주서 — 동의 버튼 상단 안내(노란 박스)
  timeSlotAckConsentHint String? @map("time_slot_ack_consent_hint") @db.Text
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("order_form_config")
}

/// 발주서 입력 필드 타입 (동적 발주서 빌더)
enum OrderFormFieldInputType {
  TEXT
  TEXTAREA
  NUMBER
  MONEY
  DATE
  TIME
  PHONE
  ADDRESS
  SELECT
  MULTISELECT
  CHECKBOX
  PHOTO
}

/// 필드 값을 채우는 주체 — 고객 입력 / 관리자 발급 시 고정 / 관리자 선입력(고객 수정 가능)
enum OrderFormFieldFillMode {
  CUSTOMER
  ADMIN_LOCKED
  ADMIN_PREFILL
}

enum OrderFormTemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// 공개 발주서 렌더 방식 — STANDARD: 표준 폼 전체(레거시) / TEMPLATE: 템플릿에 넣은 항목만(필수 코어 강제 포함)
enum OrderFormTemplateRenderMode {
  STANDARD
  TEMPLATE
}

/// 동적 발주서 템플릿 (구글폼식). 테넌트별로 여러 종(기본·에어컨·특수청소 등)을 만들어 고객에 맞게 발송.
model OrderFormTemplate {
  id          String                  @id @default(uuid())
  tenantId    String                  @map("tenant_id")
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String                  @db.VarChar(128)
  /// 목록·접수 배지용 아이콘 키(선택)
  icon        String?                 @db.VarChar(32)
  description String?                 @db.Text
  status      OrderFormTemplateStatus @default(DRAFT)
  /// 공개 폼 렌더 방식 — STANDARD: 표준 폼 전체 / TEMPLATE: 템플릿 항목만
  renderMode  OrderFormTemplateRenderMode @default(STANDARD) @map("render_mode")
  /// 발행 버전 — 발행 시 +1, 제출 스냅샷에 박제
  version     Int                     @default(1)
  /// 테넌트 기본 발주서 여부(레거시 단일 발주서 이식분)
  isDefault   Boolean                 @default(false) @map("is_default")
  sortOrder   Int                     @default(0) @map("sort_order")
  createdById String?                 @map("created_by_id")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  fields     OrderFormTemplateField[]
  orderForms OrderForm[]

  @@index([tenantId, status, sortOrder])
  @@index([tenantId, isDefault])
  @@map("order_form_templates")
}

/// 발주서 템플릿의 질문(필드) 1개. systemField 가 지정되면 제출 시 Inquiry 정형 컬럼으로 투영된다.
model OrderFormTemplateField {
  id          String                  @id @default(uuid())
  tenantId    String                  @map("tenant_id")
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateId  String                  @map("template_id")
  template    OrderFormTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  /// 폼 내 고유 키(answers JSON 키). 예: customerName, airconCount
  fieldKey    String                  @map("field_key") @db.VarChar(64)
  label       String                  @db.VarChar(128)
  helpText    String?                 @map("help_text") @db.Text
  inputType   OrderFormFieldInputType @default(TEXT) @map("input_type")
  /// SELECT/MULTISELECT 보기 옵션 등(JSON 배열)
  options     Json                    @default("[]")
  /// 입력란 안에 흐리게 표시할 부연설명(주로 TEXTAREA/TEXT). null이면 미표시
  placeholder String?                 @db.VarChar(300)
  /// 단일 선택(SELECT) 표시 방식 — 'RADIO' | 'DROPDOWN'. null이면 드롭다운(기본)
  optionStyle String?                 @map("option_style") @db.VarChar(16)
  required    Boolean                 @default(false)
  sortOrder   Int                     @default(0) @map("sort_order")
  /// 코어 매핑 키(없으면 자유 필드). 예: customerName, customerPhone, address, totalAmount, areaPyeong, preferredDate, preferredTime
  systemField String?                 @map("system_field") @db.VarChar(48)
  fillMode    OrderFormFieldFillMode  @default(CUSTOMER) @map("fill_mode")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  @@unique([templateId, fieldKey])
  @@index([tenantId, templateId, sortOrder])
  @@map("order_form_template_fields")
}

model CsReport {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerName  String   @map("customer_name")
  customerPhone String   @map("customer_phone")
  content       String
  /// 고객 서비스 품질 평가 (1~5, 별점)
  serviceRating Int?     @map("service_rating")
  imageUrls     Json     @map("image_urls") // ["url1","url2"]
  status        String   @default("RECEIVED") @map("status")
  memo          String?  @map("memo")
  createdAt     DateTime @default(now()) @map("created_at")
  /// 접수 목록(inquiries)과 이름·연락처 매칭 시 연결 (미매칭이면 null)
  inquiryId     String?  @map("inquiry_id")
  inquiry       Inquiry? @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  /// 처리완료 시각 (상태가 DONE으로 최초 전환될 때 기록)
  completedAt       DateTime? @map("completed_at")
  completedById     String?   @map("completed_by_id")
  completedBy       User?     @relation("CsReportCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  /// 어떤 방법으로 처리했는지 (전화 안내, 재방문 등)
  completionMethod  String?   @map("completion_method") @db.Text
  /// 관리자가 팀장/타업체 계정으로 C/S를 넘길 때 대상 사용자 (접수 미연결·미배정 건 전달용)
  forwardedToUserId String?  @map("forwarded_to_user_id")
  forwardedToUser   User?    @relation("CsReportForwardedTo", fields: [forwardedToUserId], references: [id], onDelete: SetNull)
  /// A/S(재방문 등) 예정일 — 관리 스케줄에만 표시, 일반 예약일·팀 캘린더 슬롯에는 반영하지 않음
  asServiceDate     DateTime? @map("as_service_date") @db.Date

  @@index([tenantId, createdAt])
  @@index([inquiryId])
  @@index([completedById])
  @@index([status])
  @@index([forwardedToUserId])
  @@index([asServiceDate])
  @@map("cs_reports")
}

/// 텔레마케팅 업무 종료 시 채널별 입력 방식
enum AdChannelSettlementMode {
  /** 채널당 당일 광고비(원) 한 번 입력 */
  DIRECT_AMOUNT
  /** 과목(건수)×건당금액으로 합산 — 과목은 AdChannelLineItem 으로 설정 */
  COUNT_LINES
}

model AdChannel {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  settlementMode AdChannelSettlementMode @default(DIRECT_AMOUNT) @map("settlement_mode")

  spendLines AdSpendLine[]
  lineItems  AdChannelLineItem[]

  @@index([tenantId, sortOrder])
  @@map("ad_channels")
}

/// 채널별 광고비 과목(숨고 받은요청·자동견적 등). 건당 금액 0 + 집계 제외면 참고 건수만(예: 예약확정 건수).
model AdChannelLineItem {
  id               String   @id @default(uuid())
  channelId        String   @map("channel_id")
  label            String   @db.VarChar(128)
  unitAmountWon    Int      @map("unit_amount_won")
  /// false 이면 금액 합산에 포함하지 않음. 건수는 종료 화면에서 「총 광고비÷합산 제외 과목 건수」 평균 분모로 자동 사용.
  countsForSpend   Boolean  @default(true) @map("counts_for_spend")
  /** 저장 필드: 항상 !countsForSpend 와 동기화(API 자동). 스냅샷 JSON 호환용. */
  useAsAvgDenominator Boolean @default(false) @map("use_as_avg_denominator")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")

  channel AdChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, sortOrder])
  @@map("ad_channel_line_items")
}

model AdWorkSession {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id")
  startedAt DateTime  @map("started_at")
  endedAt   DateTime? @map("ended_at")
  /// 평균 분모용 예약(고객 발주서 제출) 건수. 자동 집계 또는 수동 입력 최종값.
  bookingDenominatorCount Int? @map("booking_denominator_count")
  /// true면 종료 시점에 사용자가 수동 입력한 건수를 사용함
  bookingDenominatorManual Boolean @default(false) @map("booking_denominator_manual")

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  spendLines AdSpendLine[]

  @@index([tenantId, userId, startedAt])
  @@index([userId, endedAt])
  @@map("ad_work_sessions")
}

model AdSpendLine {
  id        String @id @default(uuid())
  sessionId String @map("session_id")
  channelId String @map("channel_id")
  amount    Int
  soomgoReceivedCount Int? @map("soomgo_received_count")
  soomgoAutoEstimateCount Int? @map("soomgo_auto_estimate_count")
  soomgoConfirmedCount Int? @map("soomgo_confirmed_count")
  /// COUNT_LINES 채널 저장 시 과목별 건수 스냅샷(JSON 배열)
  countBreakdown Json? @map("count_breakdown")

  session AdWorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  channel AdChannel     @relation(fields: [channelId], references: [id], onDelete: Restrict)

  @@unique([sessionId, channelId])
  @@map("ad_spend_lines")
}

model OrderForm {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// 발급 시 고정 — 고객 링크·제출 시 브랜드 귀속
  operatingCompanyId String? @map("operating_company_id")
  operatingCompany   OperatingCompany? @relation(fields: [operatingCompanyId], references: [id], onDelete: SetNull)
  token           String   @unique
  customerName    String   @map("customer_name")
  /// 발급 시 관리자가 넣는 대표 연락처(선택) — 고객 발주서 전화란에 자동 반영
  customerPhone   String?  @map("customer_phone")
  totalAmount     Int      @map("total_amount")
  depositAmount   Int      @default(20000) @map("deposit_amount")
  balanceAmount   Int      @map("balance_amount")
  optionNote      String?  @map("option_note")
  preferredDate       String?  @map("preferred_date")   // YYYY-MM-DD, 관리자 설정
  preferredTime       String?  @map("preferred_time")    // 오전/오후/사이청소
  preferredTimeDetail String?  @map("preferred_time_detail") // 구체적 시각 (선택)
  /// 발급 시 마케터가 지정한 청소 면적(평) — 있으면 고객 발주서에서 수정 불가
  areaPyeong      Float?   @map("area_pyeong")
  areaBasis       String?  @map("area_basis")
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  submittedAt     DateTime? @map("submitted_at")
  /// 고객 발주서 「특이사항」 자유 입력 — 접수 `specialNotes`(관리자·팀 공유)와 분리
  customerSpecialNotes String? @map("customer_special_notes") @db.Text
  customerSubmissionSnapshot Json? @map("customer_submission_snapshot")
  /// 동적 템플릿 추가 항목(systemField 미연결)의 고객 답변 {fieldKey: value}
  customerAnswers Json? @map("customer_answers")
  /// 마케터가 발급/수정 시 미리 채운 값 {key: value} — 표준 항목 키(customerName 등) + 커스텀 fieldKey 통합.
  /// 값이 들어간 키는 고객 화면에서 읽기전용(확인 전용)으로 잠긴다. 제출 시 잠금 키는 이 값이 우선.
  prefillAnswers Json? @map("prefill_answers")
  /// 이 발급이 사용하는 동적 발주서 템플릿(레거시 발급은 테넌트 기본 템플릿)
  templateId      String?  @map("template_id")
  template        OrderFormTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  /// 발급 시점 템플릿 버전(스냅샷)
  templateVersion Int?     @map("template_version")
  reviewPaybackToken String? @unique @map("review_payback_token")

  createdBy  User      @relation("OrderFormCreatedBy", fields: [createdById], references: [id])
  inquiries  Inquiry[]
  photos     OrderFormPhoto[]
  reviewPaybackRequest ReviewPaybackRequest?

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([tenantId, templateId])
  @@index([tenantId, operatingCompanyId])
  @@map("order_forms")
}

/// 고객이 발주서 제출 전·후 첨부한 현장 사진 (Cloudinary).
/// 추가 견적 산정 근거 — 관리자/팀장은 접수 상세에서 열람해 오염 정도·특이 구역을 확인한다.
model OrderFormPhoto {
  id                 String   @id @default(uuid())
  orderFormId        String   @map("order_form_id")
  cloudinaryPublicId String   @map("cloudinary_public_id") @db.VarChar(512)
  secureUrl          String   @map("secure_url") @db.VarChar(1024)
  width              Int?
  height             Int?
  createdAt          DateTime @default(now()) @map("created_at")

  orderForm OrderForm @relation(fields: [orderFormId], references: [id], onDelete: Cascade)

  @@index([orderFormId, createdAt])
  @@map("order_form_photos")
}

/// 발주서 삭제 로그 (관리자/마케터, 비밀번호 검증 후 삭제 시 기록)
model OrderFormDeleteLog {
  id           String   @id @default(uuid())
  orderFormId  String   @map("order_form_id")
  actorId      String   @map("actor_id")
  actorRole    String   @map("actor_role") @db.VarChar(32)
  /// 발급 마케터 — 광고 예약 분모 삭제 건수 귀속
  createdById  String   @map("created_by_id")
  customerName String   @map("customer_name")
  totalAmount  Int      @map("total_amount")
  /// 삭제 시점 발주서 제출 여부(미제출이면 null)
  submittedAt  DateTime? @map("submitted_at")
  /// 삭제 시점 발주서 발급 시각 — 미제출 분모 구간 판별
  orderFormCreatedAt DateTime @map("order_form_created_at")
  deletedAt    DateTime @default(now()) @map("deleted_at")

  actor     User @relation("OrderFormDeleteLogActor", fields: [actorId], references: [id], onDelete: Restrict)
  createdBy User @relation("OrderFormDeleteLogCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([orderFormId, deletedAt])
  @@index([actorId, deletedAt])
  @@index([createdById, submittedAt])
  @@index([createdById, orderFormCreatedAt])
  @@map("order_form_delete_logs")
}

/// 발주서 메뉴 「부재현황」— 전화 부재·예약금 대기·보류 등 후속 관리
enum OrderFollowupStatus {
  /// 부재·보류 화면: 고객 요청·의뢰 단계
  REQUESTED
  ABSENT
  DEPOSIT_PENDING
  ON_HOLD
  RESERVED
  FULFILLED
}

model OrderFollowup {
  id                 String               @id @default(uuid())
  tenantId           String               @map("tenant_id")
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inquiryId          String?              @map("inquiry_id")
  customerName       String               @map("customer_name")
  nickname           String?              @map("nickname")
  customerPhone      String               @map("customer_phone")
  status             OrderFollowupStatus  @map("status")
  deferCount         Int                  @default(0) @map("defer_count")
  goldDb             Boolean              @default(false) @map("gold_db")
  /// 입주청소 희망일(선택) — YYYY-MM-DD 문자열
  preferredMoveInCleaningDate String?     @map("preferred_move_in_cleaning_date") @db.VarChar(10)
  memo               String?              @map("memo") @db.Text
  nextContactAt      DateTime?            @map("next_contact_at")
  depositReceivedAt  DateTime?            @map("deposit_received_at")
  createdById        String               @map("created_by_id")
  handledById        String?              @map("handled_by_id")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  inquiry   Inquiry? @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  createdBy       User       @relation("OrderFollowupCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  handledBy       User?      @relation("OrderFollowupHandledBy", fields: [handledById], references: [id], onDelete: SetNull)
  logs              OrderFollowupLog[]

  @@index([tenantId, status, updatedAt])
  @@index([status, updatedAt])
  @@index([status, createdAt(sort: Desc)])
  @@index([handledById])
  @@index([inquiryId])
  @@map("order_followups")
}

model OrderFollowupLog {
  id          String   @id @default(uuid())
  followupId  String   @map("followup_id")
  actorId     String   @map("actor_id")
  action      String   @map("action") @db.VarChar(64)
  detail      String?  @map("detail") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  followup OrderFollowup @relation(fields: [followupId], references: [id], onDelete: Cascade)
  actor    User          @relation("OrderFollowupLogActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([followupId, createdAt])
  @@map("order_followup_logs")
}

enum ReviewPaybackStatus {
  PENDING
  VERIFIED
  PAID
  REJECTED
}

model ReviewPaybackRequest {
  id                  String              @id @default(uuid())
  tenantId            String              @map("tenant_id")
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderFormId         String              @unique @map("order_form_id")
  orderForm           OrderForm           @relation(fields: [orderFormId], references: [id], onDelete: Cascade)
  inquiryId           String?             @map("inquiry_id")
  inquiry             Inquiry?            @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  customerName        String              @map("customer_name")
  customerPhone       String?             @map("customer_phone")
  bankName            String              @map("bank_name")
  accountNumber       String              @map("account_number")
  reviewImageUrl      String              @map("review_image_url") @db.VarChar(1024)
  reviewImagePublicId String?             @map("review_image_public_id") @db.VarChar(512)
  /// [{ url, publicId? }] — 목록 썸네일은 reviewImageUrl(첫 장) 유지
  reviewImages        Json                @default("[]") @map("review_images")
  status              ReviewPaybackStatus @default(PENDING)
  adminMemo           String?             @map("admin_memo") @db.Text
  handledById         String?             @map("handled_by_id")
  handledBy           User?               @relation("ReviewPaybackHandledBy", fields: [handledById], references: [id], onDelete: SetNull)
  seenAt              DateTime?           @map("seen_at")
  submittedAt         DateTime            @default(now()) @map("submitted_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@index([tenantId, status, submittedAt(sort: Desc)])
  @@index([tenantId, seenAt, status])
  @@map("review_payback_requests")
}

enum InquiryStatus {
  PENDING       // 대기 (마케터 선접수, 고객 발주서 미제출)
  RECEIVED      // 접수
  /// 입금 확인 전(이 상태로 전환 시 접수번호 발급)
  DEPOSIT_PENDING
  /// 입금 완료·발주서 미제출 전(접수 목록에 표시)
  DEPOSIT_COMPLETED
  /// 발주서 링크 발급 후 고객 제출 대기(접수 목록에서「미제출」)
  ORDER_FORM_PENDING
  ASSIGNED      // 분배완료
  IN_PROGRESS   // 진행중
  COMPLETED     // 완료
  CANCELLED     // 취소
  CS_PROCESSING // C/S 처리중
  ON_HOLD       // 보류 (일정 미확정 등)
}

model Assignment {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inquiryId     String   @map("inquiry_id")
  teamLeaderId  String   @map("team_leader_id")
  assignedById  String   @map("assigned_by_id")
  assignedAt    DateTime @default(now()) @map("assigned_at")
  /// 팀장이 접수 상세 모달로 확인한 시각 — null이면 메뉴 미확인 배지에 포함
  detailViewedAt DateTime? @map("detail_viewed_at")
  /// 같은 접수에 팀장 여러 명일 때 표시 순서
  sortOrder     Int      @default(0) @map("sort_order")

  inquiry     Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  teamLeader  User    @relation("TeamLeaderAssignments", fields: [teamLeaderId], references: [id])
  assignedBy  User    @relation("AdminAssignments", fields: [assignedById], references: [id])

  @@index([tenantId, inquiryId])
  @@index([inquiryId])
  @@index([teamLeaderId])
  @@map("assignments")
}

model Message {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  senderId   String    @map("sender_id")
  receiverId String    @map("receiver_id")
  content    String
  readAt     DateTime? @map("read_at")
  createdAt  DateTime @default(now()) @map("created_at")
  batchId    String?   @map("batch_id")

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([tenantId, receiverId, readAt])
  @@index([batchId])
  @@index([receiverId, readAt])
  @@index([senderId, receiverId, createdAt])
  @@map("messages")
}

/// 사용자별 맞춤 '지역 필터 캘린더'
/// 관리자·마케터가 자주 보는 지역 묶음을 저장해 스케줄 화면에서 빠르게 전환한다.
/// `regions` 는 시 단위 문자열 배열(JSON). 예: ["천안시","아산시","대전광역시"]
/// 접수 address 문자열에 시 단위 이름이 단어 경계로 포함되면 일치로 간주(클라이언트 필터).
model UserCustomCalendar {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  name      String   @db.VarChar(64)
  regions   Json
  /// 탭 색상 키 — `CUSTOM_CALENDAR_COLOR_KEYS`(클라·서버 constants)에 정의된 짧은 영문 식별자
  colorKey  String   @default("teal") @map("color_key") @db.VarChar(16)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation("UserCustomCalendars", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, sortOrder])
  @@map("user_custom_calendars")
}

/// 갑(인) 칸에 넣을 이미지 종류 — 동일 토큰 `[[EC_ISSUER_SEAL]]` 로 치환.
enum EContractIssuerStampKind {
  SEAL
  SIGNATURE
}

/// 전자계약 발행측(갑) 표기 — 본문 `[[EC_ISSUER_*]]` 치환·배포 시점 스냅샷.
/// 다법인 시 `profile_key`로 확장 가능(단일테넌트는 `default`).
model EContractIssuerProfile {
  id                       String                     @id @default(uuid())
  tenantId                 String                     @map("tenant_id")
  tenant                   Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profileKey               String                     @default("default") @map("profile_key") @db.VarChar(64)
  companyName              String                     @default("") @map("company_name") @db.VarChar(512)
  representativeName       String?                    @map("representative_name") @db.VarChar(128)
  businessRegistrationNo   String?                  @map("business_registration_no") @db.VarChar(32)
  addressLine              String?                    @map("address_line") @db.Text
  phone                    String?                    @db.VarChar(64)
  fax                      String?                    @db.VarChar(64)
  email                    String?                    @db.VarChar(256)
  issuerStampKind          EContractIssuerStampKind   @default(SEAL) @map("issuer_stamp_kind")
  sealPublicId             String?                    @map("seal_public_id") @db.VarChar(512)
  sealSecureUrl            String?                    @map("seal_secure_url") @db.VarChar(2048)
  sealDisplayWidthPx       Int?                       @map("seal_display_width_px")
  signaturePublicId        String?                    @map("signature_public_id") @db.VarChar(512)
  signatureSecureUrl       String?                    @map("signature_secure_url") @db.VarChar(2048)
  signatureDisplayWidthPx  Int?                       @map("signature_display_width_px")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")
  updatedById              String?  @map("updated_by_id")
  updatedBy                User?    @relation("EContractIssuerProfileUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, profileKey])
  @@map("e_contract_issuer_profiles")
}

/// 팀장 전자계약 — 계약 종류(정의). 본문 히스토리는 `EContractVersion`.
/// 모듈: `server/src/modules/e-contract`
enum EContractVersionStatus {
  DRAFT
  PUBLISHED
}

enum EContractIssuanceStatus {
  PENDING
  OPENED
  SIGNED
  EXPIRED
  REVOKED
}

/// 계약서 수신 대상 — 팀장(팀 화면) / 마케터(링크만)
enum EContractAudience {
  TEAM_LEADER
  MARKETER
}

/// 체결·매핑 필드 — 값을 채우는 주체
enum EContractFieldFilledBy {
  SIGNER
  ADMIN
  AUTO
}

enum EContractFieldInputType {
  TEXT
  TEXTAREA
  DATE
  NUMBER
  PHONE
  RRN
}

/// 전자계약 본문 치환 필드 정의(팀장/마케터별 설정)
model EContractFieldDefinition {
  id         String                   @id @default(uuid())
  tenantId   String                   @map("tenant_id")
  tenant     Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  audience   EContractAudience        @map("audience")
  /// 본문 삽입 토큰 — 예: [[EC_SIGNER_NAME]]
  token      String                   @db.VarChar(64)
  label      String                   @db.VarChar(128)
  inputType  EContractFieldInputType  @default(TEXT) @map("input_type")
  filledBy   EContractFieldFilledBy   @map("filled_by")
  required   Boolean                  @default(true)
  sortOrder  Int                      @default(0) @map("sort_order")
  isActive   Boolean                  @default(true) @map("is_active")
  createdAt  DateTime                 @default(now()) @map("created_at")
  updatedAt  DateTime                 @updatedAt @map("updated_at")

  @@unique([tenantId, audience, token])
  @@index([tenantId, audience, isActive, sortOrder])
  @@map("e_contract_field_definitions")
}

model EContractDefinition {
  id           String             @id @default(uuid())
  tenantId     String             @map("tenant_id")
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title        String             @db.VarChar(512)
  description  String?            @db.Text
  /// 수신자 유형 — 발급·체결 대상(팀장 vs 마케터 링크)
  audience     EContractAudience  @default(TEAM_LEADER) @map("audience")
  /// 보관 종료 etc — 목록에서 기본 숨김 처리에 사용 (체결본은 유지)
  isArchived   Boolean            @default(false) @map("is_archived")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdById  String?   @map("created_by_id")

  createdBy User?               @relation("EContractDefinitionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  versions  EContractVersion[]
  issuances EContractIssuance[]

  @@index([tenantId, isArchived, updatedAt(sort: Desc)])
  @@map("e_contract_definitions")
}

/// 계약 문안 버전 — 발행 후 본문·해시 변경 금지(서비스 레이어). 히스토리 = 같은 definitionId 행 묶음.
model EContractVersion {
  id                 String                   @id @default(uuid())
  definitionId       String                   @map("definition_id")
  status             EContractVersionStatus   @default(DRAFT)
  /// 배포 순번(1,2,…). 초안은 null.
  publishedOrdinal   Int?                     @map("published_ordinal")
  /// 배포 시점 문서 제목 스냅샷
  titleSnapshot      String                   @map("title_snapshot") @db.VarChar(512)
  /// 관리자 편집본(표시 시 마크다운→HTML 등 클라에서 처리 가능)
  bodyMarkdown       String                   @map("body_markdown") @db.Text
  /// 배포 시점 발행측 스냅샷(JSON). 레거시 배포는 null.
  issuerSnapshot     Json?                    @map("issuer_snapshot")
  /// 배포 후 체결자에게 보이는 HTML(플레이스홀더 치환 후). 없으면 `bodyMarkdown` 그대로.
  bodyDisplayHtml    String?                  @map("body_display_html") @db.Text
  /// 배포 시 본문+제목+ordinal 정규 문자열 해시(hex) — 「당시 문안」증명용
  contentHash        String?                  @map("content_hash") @db.VarChar(128)
  publishedAt        DateTime?                @map("published_at")
  publishedById      String?                  @map("published_by_id")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  definition  EContractDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  publishedBy User?               @relation("EContractVersionPublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  issuances   EContractIssuance[]
  submissions EContractSubmission[]

  @@unique([definitionId, publishedOrdinal])
  @@index([definitionId, status])
  @@map("e_contract_versions")
}

/// 팀장에게 낸 링크(토큰) 1건 — 어느 배포 버전으로 체결 대상인지 고정.
model EContractIssuance {
  id             String                  @id @default(uuid())
  token          String                  @unique @db.VarChar(128)
  definitionId   String                  @map("definition_id")
  versionId      String                  @map("version_id")
  teamLeaderId   String                  @map("team_leader_id")
  status         EContractIssuanceStatus @default(PENDING)
  expiresAt      DateTime?               @map("expires_at")
  notes          String?                 @db.Text
  /// 발급 시 관리자 입력 치환값 — token → 표시 문자열
  mergeFields    Json?                   @map("merge_fields")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  definition EContractDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  version    EContractVersion    @relation(fields: [versionId], references: [id], onDelete: Restrict)
  teamLeader User                @relation("EContractIssuanceTeamLeader", fields: [teamLeaderId], references: [id], onDelete: Cascade)
  submission EContractSubmission?

  @@index([teamLeaderId, createdAt(sort: Desc)])
  @@index([definitionId, versionId])
  @@map("e_contract_issuances")
}

/// 체결 완료 1건(감사 로그 코어). `versionContentHash`는 배포 당시 `EContractVersion.contentHash` 복사.
model EContractSubmission {
  id                  String   @id @default(uuid())
  issuanceId          String   @unique @map("issuance_id")
  versionId           String   @map("version_id")
  signedAt            DateTime @default(now()) @map("signed_at")
  payload             Json?
  versionContentHash  String?  @map("version_content_hash") @db.VarChar(128)
  selfiePublicId      String?  @map("selfie_public_id") @db.VarChar(512)
  selfieUrl           String?  @map("selfie_url") @db.VarChar(2048)
  signaturePublicId   String?  @map("signature_public_id") @db.VarChar(512)
  signatureUrl        String?  @map("signature_url") @db.VarChar(2048)
  /// 체결 직후 버전 본문에 을 정보·서명 토큰을 치환한 HTML(감사·열람용)
  mergedContractHtml  String?  @map("merged_contract_html") @db.Text
  finalPdfPublicId    String?  @map("final_pdf_public_id") @db.VarChar(512)
  finalPdfUrl         String?  @map("final_pdf_url") @db.VarChar(2048)
  signerUserAgent     String?  @map("signer_user_agent") @db.VarChar(512)
  signerIp            String?  @map("signer_ip") @db.VarChar(64)

  issuance EContractIssuance @relation(fields: [issuanceId], references: [id], onDelete: Cascade)
  version  EContractVersion  @relation(fields: [versionId], references: [id], onDelete: Restrict)

  @@index([versionId, signedAt(sort: Desc)])
  @@map("e_contract_submissions")
}
