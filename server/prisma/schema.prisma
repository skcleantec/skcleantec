generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole @default(TEAM_LEADER)
  phone        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  assignmentsAssigned Assignment[] @relation("TeamLeaderAssignments")
  assignmentsGiven     Assignment[] @relation("AdminAssignments")
  sentMessages        Message[]    @relation("SentMessages")
  receivedMessages    Message[]    @relation("ReceivedMessages")
  dayOffs             UserDayOff[] @relation("UserDayOffs")
  orderFormsCreated   OrderForm[]  @relation("OrderFormCreatedBy")
  inquiriesCreated    Inquiry[]    @relation("InquiryCreatedBy")
  adWorkSessions      AdWorkSession[]
  /// 팀장당 1팀 (비로그인 팀원·휴무)
  team                Team? @relation("TeamLeaderTeam")
  scheduleDayLeaderSlots ScheduleDayLeaderSlot[]
  inquiryCleaningPhotosUploaded InquiryCleaningPhoto[] @relation("CleaningPhotoUploader")

  @@map("users")
}

/// 팀장당 1팀 (팀원은 로그인 없음, 마스터·휴무만 관리)
model Team {
  id           String   @id @default(uuid())
  teamLeaderId String   @unique @map("team_leader_id")
  memo         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  teamLeader User         @relation("TeamLeaderTeam", fields: [teamLeaderId], references: [id], onDelete: Cascade)
  members    TeamMember[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid())
  /// null이면 팀장 소속 없이 전사 풀 팀원
  teamId    String?  @map("team_id")
  name      String
  phone     String?
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  team    Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  dayOffs TeamMemberDayOff[]
  scheduleDaySlots ScheduleDayTeamMemberSlot[]

  @@map("team_members")
}

model TeamMemberDayOff {
  id           String   @id @default(uuid())
  teamMemberId String   @map("team_member_id")
  date         DateTime @db.Date @map("date")
  createdAt    DateTime @default(now()) @map("created_at")

  teamMember TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@unique([teamMemberId, date])
  @@map("team_member_day_offs")
}

model UserDayOff {
  id            String   @id @default(uuid())
  teamLeaderId  String   @map("team_leader_id")
  date          DateTime @db.Date @map("date")
  createdAt     DateTime @default(now()) @map("created_at")

  teamLeader User @relation("UserDayOffs", fields: [teamLeaderId], references: [id], onDelete: Cascade)

  @@unique([teamLeaderId, date])
  @@map("user_day_offs")
}

enum UserRole {
  ADMIN
  TEAM_LEADER
  MARKETER
}

/// KST 일자별 접수 순번 (YYMMDD + 4자리 = 10자리 `inquiry_number` 발급용)
model DailyInquiryCounter {
  dateKey String @id @map("date_key") @db.VarChar(8)
  lastSeq Int    @map("last_seq")

  @@map("daily_inquiry_counters")
}

model Inquiry {
  id              String       @id @default(uuid())
  /// 고객·검색용 짧은 접수번호 (KST 기준 YYMMDD + 일 4자리 순번, 10자리 숫자, 전역 유일)
  inquiryNumber   String?      @unique @map("inquiry_number") @db.VarChar(12)
  customerName    String       @map("customer_name")
  customerPhone   String       @map("customer_phone")
  customerPhone2  String?      @map("customer_phone_2")
  address         String
  addressDetail   String?      @map("address_detail")
  areaPyeong      Float?       @map("area_pyeong")
  areaBasis       String?      @map("area_basis")
  propertyType    String?      @map("property_type")
  roomCount       Int?         @map("room_count")
  bathroomCount   Int?         @map("bathroom_count")
  balconyCount    Int?         @map("balcony_count")
  preferredDate       DateTime? @map("preferred_date")
  preferredTime       String?   @map("preferred_time")
  /// 사이청소만: 미확정 null, 확정 시 오전/오후 중 하나(해당 슬롯 1건 소모)
  betweenScheduleSlot String?   @map("between_schedule_slot")
  preferredTimeDetail String?   @map("preferred_time_detail")
  callAttempt     Int?         @map("call_attempt")
  memo            String?
  claimMemo       String?       @map("claim_memo")
  status          InquiryStatus @default(RECEIVED)
  source          String?      @default("전화")
  createdAt       DateTime     @default(now()) @map("created_at")
  /// 팀장이 고객에게 전화로 일정 안내(해피콜) 완료 시각 — 미입력이면 미완료
  happyCallCompletedAt DateTime? @map("happy_call_completed_at")

  assignments   Assignment[]
  buildingType String?       @map("building_type")
  moveInDate   DateTime?     @map("move_in_date")
  specialNotes String?       @map("special_notes")
  kitchenCount Int?          @map("kitchen_count")
  /// 정산·스케줄용 금액(발주서 연동 시 자동 입력, 개별 접수는 관리자 입력)
  serviceTotalAmount   Int? @map("service_total_amount")
  serviceDepositAmount Int? @map("service_deposit_amount")
  serviceBalanceAmount Int? @map("service_balance_amount")
  /// 현장 투입 비로그인 팀원 인원 수(관리자 입력)
  crewMemberCount Int?       @map("crew_member_count")
  /// 팀원 누구 투입 등 수기 메모(예: 김,태)
  crewMemberNote  String?    @map("crew_member_note")
  /// 스케줄 목록(이름·접수번호 옆)에만 쓰는 짧은 메모 — 특이사항·발주서 메모와 별개
  scheduleMemo    String?    @map("schedule_memo")
  orderFormId  String?       @map("order_form_id")
  /// 접수 등록자(마케터 등). 발주서 제출 시 발주서 생성 마케터 기준.
  createdById  String?       @map("created_by_id")
  /// 전문 시공 옵션 id 목록(JSON 배열 문자열)
  professionalOptionIds Json? @map("professional_option_ids")

  orderForm   OrderForm?          @relation(fields: [orderFormId], references: [id])
  createdBy   User?               @relation("InquiryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  changeLogs  InquiryChangeLog[]
  cleaningPhotos InquiryCleaningPhoto[]

  @@map("inquiries")
}

enum CleaningPhotoPhase {
  BEFORE
  AFTER
}

/// 현장 청소 전·후 사진 (Cloudinary)
model InquiryCleaningPhoto {
  id                 String   @id @default(uuid())
  inquiryId          String   @map("inquiry_id")
  phase              CleaningPhotoPhase @map("phase")
  cloudinaryPublicId String   @map("cloudinary_public_id") @db.VarChar(512)
  secureUrl          String   @map("secure_url") @db.VarChar(1024)
  width              Int?
  height             Int?
  uploadedById       String   @map("uploaded_by_id")
  createdAt          DateTime @default(now()) @map("created_at")

  inquiry    Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("CleaningPhotoUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([inquiryId, phase, createdAt])
  @@map("inquiry_cleaning_photos")
}

enum ScheduleClosureScope {
  FULL
  MORNING
  AFTERNOON
}

/// 관리자 수동 일정 마감(범위별 잔여 슬롯·TO 조정)
model ScheduleDayClosure {
  id        String               @id @default(uuid())
  date      DateTime             @unique @db.Date @map("date")
  scope     ScheduleClosureScope @default(FULL) @map("scope")
  createdAt DateTime             @default(now()) @map("created_at")

  @@map("schedule_day_closures")
}

/// 일자별 팀장 오전·오후 가용(관리자 수동, 없으면 휴무일 기준)
model ScheduleDayLeaderSlot {
  id                 String   @id @default(uuid())
  date               DateTime @db.Date @map("date")
  teamLeaderId       String   @map("team_leader_id")
  morningAvailable   Boolean  @map("morning_available")
  afternoonAvailable Boolean  @map("afternoon_available")
  note               String?  @map("note")

  teamLeader User @relation(fields: [teamLeaderId], references: [id], onDelete: Cascade)

  @@unique([date, teamLeaderId])
  @@map("schedule_day_leader_slots")
}

/// 일자별 팀원 가용(관리자 수동, 없으면 휴무일 기준)
model ScheduleDayTeamMemberSlot {
  id           String   @id @default(uuid())
  date         DateTime @db.Date @map("date")
  teamMemberId String   @map("team_member_id")
  available    Boolean
  note         String?  @map("note")

  teamMember TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@unique([date, teamMemberId])
  @@map("schedule_day_team_member_slots")
}

/// 발주서·접수에서 선택하는 전문 시공 옵션 (관리자 설정)
model ProfessionalSpecialtyOption {
  id        String   @id
  label     String
  priceHint String?  @map("price_hint")
  emoji     String?
  color     String?
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("professional_specialty_options")
}

/// 관리자 수정 시 날짜·금액 등 변경 이력 (접수 목록·스케줄에서 조회)
model InquiryChangeLog {
  id        String   @id @default(uuid())
  inquiryId String   @map("inquiry_id")
  createdAt DateTime @default(now()) @map("created_at")
  actorId   String?  @map("actor_id")
  lines     Json

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId, createdAt(sort: Desc)])
  @@map("inquiry_change_logs")
}

model EstimateConfig {
  id             String   @id @default(uuid())
  pricePerPyeong Int      @map("price_per_pyeong")
  depositAmount  Int      @default(20000) @map("deposit_amount")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("estimate_config")
}

model EstimateOption {
  id          String   @id @default(uuid())
  name        String
  extraAmount Int      @map("extra_amount")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("estimate_options")
}

model OrderFormConfig {
  id                  String   @id @default(uuid())
  formTitle           String   @default("SK클린텍 입주청소 발주서") @map("form_title")
  priceLabel          String?  @default("(특가)") @map("price_label")
  reviewEventText     String?  @map("review_event_text")
  footerNotice1       String?  @map("footer_notice_1")
  footerNotice2       String?  @map("footer_notice_2")
  infoContent         String?  @map("info_content")
  infoLinkText        String?  @map("info_link_text")
  submitSuccessTitle  String?  @map("submit_success_title")
  submitSuccessBody   String?  @map("submit_success_body")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("order_form_config")
}

model CsReport {
  id            String   @id @default(uuid())
  customerName  String   @map("customer_name")
  customerPhone String   @map("customer_phone")
  content       String
  imageUrls     Json     @map("image_urls") // ["url1","url2"]
  status        String   @default("RECEIVED") @map("status")
  memo          String?  @map("memo")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("cs_reports")
}

model AdChannel {
  id        String   @id @default(uuid())
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  spendLines AdSpendLine[]

  @@map("ad_channels")
}

model AdWorkSession {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  startedAt DateTime  @map("started_at")
  endedAt   DateTime? @map("ended_at")

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  spendLines AdSpendLine[]

  @@index([userId, startedAt])
  @@index([userId, endedAt])
  @@map("ad_work_sessions")
}

model AdSpendLine {
  id        String @id @default(uuid())
  sessionId String @map("session_id")
  channelId String @map("channel_id")
  amount    Int

  session AdWorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  channel AdChannel     @relation(fields: [channelId], references: [id], onDelete: Restrict)

  @@unique([sessionId, channelId])
  @@map("ad_spend_lines")
}

model OrderForm {
  id              String   @id @default(uuid())
  token           String   @unique
  customerName    String   @map("customer_name")
  totalAmount     Int      @map("total_amount")
  depositAmount   Int      @default(20000) @map("deposit_amount")
  balanceAmount   Int      @map("balance_amount")
  optionNote      String?  @map("option_note")
  preferredDate       String?  @map("preferred_date")   // YYYY-MM-DD, 관리자 설정
  preferredTime       String?  @map("preferred_time")    // 오전/오후/사이청소
  preferredTimeDetail String?  @map("preferred_time_detail") // 구체적 시각 (선택)
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  submittedAt     DateTime? @map("submitted_at")

  createdBy  User      @relation("OrderFormCreatedBy", fields: [createdById], references: [id])
  inquiries  Inquiry[]

  @@map("order_forms")
}

enum InquiryStatus {
  PENDING       // 대기 (마케터 선접수, 고객 발주서 미제출)
  RECEIVED      // 접수
  ASSIGNED      // 분배완료
  IN_PROGRESS   // 진행중
  COMPLETED     // 완료
  CANCELLED     // 취소
  CS_PROCESSING // C/S 처리중
}

model Assignment {
  id            String   @id @default(uuid())
  inquiryId     String   @map("inquiry_id")
  teamLeaderId  String   @map("team_leader_id")
  assignedById  String   @map("assigned_by_id")
  assignedAt    DateTime @default(now()) @map("assigned_at")
  /// 같은 접수에 팀장 여러 명일 때 표시 순서
  sortOrder     Int      @default(0) @map("sort_order")

  inquiry     Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  teamLeader  User    @relation("TeamLeaderAssignments", fields: [teamLeaderId], references: [id])
  assignedBy  User    @relation("AdminAssignments", fields: [assignedById], references: [id])

  @@index([inquiryId])
  @@map("assignments")
}

model Message {
  id         String    @id @default(uuid())
  senderId   String    @map("sender_id")
  receiverId String    @map("receiver_id")
  content    String
  readAt     DateTime? @map("read_at")
  createdAt  DateTime @default(now()) @map("created_at")

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("messages")
}
