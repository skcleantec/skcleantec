# Railway staging 환경 Postgres — 로컬 PC에서 접속 가능한 공개(Proxy) URL만 사용
# (postgres.railway.internal 은 로컬에서 동작하지 않음)
#
# 설정 방법:
# 1. Railway Dashboard → 환경 staging → Postgres → Connect / Variables
# 2. *.proxy.rlwy.net 형태의 DATABASE_URL(또는 DATABASE_PUBLIC_URL) 복사
# 3. 이 파일을 server/.env.staging 으로 복사한 뒤 아래 한 줄을 붙여넣기
# 4. npm run dev (또는 dev.bat) 재시작
#
# 자세히: STAGING_SETUP.md 「로컬 server/.env를 스테이징 DB로 맞추기」

DATABASE_URL="postgresql://USER:PASSWORD@HOST.proxy.rlwy.net:PORT/railway?sslmode=require"
JWT_SECRET="dev-secret-change-in-production"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development
