{
  "name": "skcleanteck",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "cd server && npm run build && cd ../client && npm run build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:setup": "cd server && npx prisma db push && npm run db:seed && npm run db:backfill-inquiry-numbers",
    "db:studio": "cd server && npx prisma studio",
    "db:seed": "cd server && npm run db:seed",
    "db:check-admin": "cd server && npm run db:check-admin",
    "db:seed:schedule:test-m3-m5": "cd server && npm run db:seed:schedule:test-m3-m5",
    "db:purge:schedule:test-m3-m5": "cd server && npm run db:purge:schedule:test-m3-m5",
    "deploy:seed-from-config": "cd server && npm run deploy:seed-from-config",
    "db:backfill-seed-inquiries-created-by": "cd server && npm run db:backfill-seed-inquiries-created-by",
    "db:seed:unassigned-month": "cd server && npm run db:seed:unassigned-month"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
