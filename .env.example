# Database (PostgreSQL)
# 로컬 Docker: npm run db:up 후 예시
# DATABASE_URL="postgresql://skcleanteck:skcleanteck@localhost:5432/skcleanteck"
# Neon 등 원격(도커 없이 개발): 대시보드에서 복사한 연결 문자열 — 보통 ?sslmode=require 포함
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://skcleanteck:skcleanteck@localhost:5432/skcleanteck"
# Prisma pool (URL에 없을 때 server/src/lib/prisma.ts가 기본 connection_limit=10, pool_timeout=20 추가)
# PRISMA_CONNECTION_LIMIT=10
# PRISMA_POOL_TIMEOUT=20
# Railway: Postgres 서비스 연결 시 자동 주입

# JWT
JWT_SECRET="change-this-secret-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000

# 운영 공개 URL (메일·서버 생성 링크 canonical). Railway Variables에 설정
# PUBLIC_URL="https://www.cbiseo.com"
# TENANT_HOST_BASE_DOMAIN=cbiseo.com
# TENANT_HOST_ALIAS_DOMAINS=skcleantec.com
# PLATFORM_HOST_SUBDOMAIN=platform

# Kakao 로컬 API (선택) — 관리자 스케줄「접수건 위치」지도에서 Nominatim 실패 시 국내 주소 재지오코딩
# Kakao Developers → 내 애플리케이션 → 앱 키 → REST API 키.
# 로컬: server/.env 또는 저장소 루트 .env(둘 다 읽음, server/.env가 우선). 운영: Railway Variables.
# KAKAO_REST_API_KEY=

# Railway·컨테이너 게이트웨이 502 방지 시 0.0.0.0 (기본값). 로컬만 쓰면 생략 가능
# LISTEN_HOST=0.0.0.0
NODE_ENV=development

# --- 스테이징 전용: 관리자 프로필 메뉴 「운영 DB 가져오기」(운영 Railway에는 설정하지 말 것)
# STAGING_DB_IMPORT_ENABLED=true
# STAGING_DB_IMPORT_SOURCE_DATABASE_URL="postgresql://...@....proxy.rlwy.net:PORT/railway?sslmode=require"
# STAGING_DB_IMPORT_OPERATOR_EMAIL_SUBSTRING=pyo
# 로컬에서만 시험: STAGING_DB_IMPORT_ALLOW_LOCAL=true

# Railway CLI (에이전트·로컬 — 숨고 연동 Variables 갱신). gitignore server/.env 에만 실제 값
# RAILWAY_TOKEN=

# Cloudinary (웹하드·이미지) — 서버 전용. 실제 값은 server/.env에만 (gitignore)
# 형식: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# CLOUDINARY_URL=

# SMTP (현장 검수 완료본 이메일 — 선택)
# · 테넌트별: 관리자 전용 → 사용자 등록 → 업체등록정보 (권장)
# · 서버 전역 fallback: 아래 변수 (테넌트 SMTP 미설정 시에만 사용)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="청소비서 <noreply@example.com>"
# INSPECTION_PDF_FONT_PATH=/usr/share/fonts/truetype/nanum/NanumGothic.ttf

# --- 클라이언트(Vite) — client/.env 에 두는 값 (루트가 아님). 운영은 Railway에서 클라이언트 빌드에 VITE_ 변수 추가
# 관리자 스케줄「접수건 위치 검색」버튼 아이콘 URL(선택). 비우면 저장소 기본 Cloudinary 이미지 사용
# 예: VITE_ADMIN_SCHEDULE_MAP_ICON_URL=https://res.cloudinary.com/.../image/upload/.../map.jpg
# 앱 공통「수정」아이콘(선택). 비우면 `client/public/icons/edit-universal.svg` — Cloudinary PNG 예: VITE_APP_EDIT_ICON_URL=https://res.cloudinary.com/.../edit.png
# 자세한 플레이스홀더: client/.env.example 참고

# (레거시) 팀장 브라우저 Web Push / WEBPUSH_VAPID_* — 앱에서 사용하지 않음. DB team_leader_web_push_subscriptions 테이블만 과거 데이터용으로 남을 수 있음.
