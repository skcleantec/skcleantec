# Dependencies
node_modules/

# Environment (보안 - 절대 push 금지)
.env
.env.local
.env.*.local
.env.postgresql
server/.env.staging
**/.env.staging

# Build output
dist/
client/dist/
server/dist/

# 정적 의존성 사본 (postinstall 로 자동 생성됨 — pagedjs polyfill 등)
client/public/vendor/

# C/S 이미지 업로드 (로컬)
server/uploads/

# SQLite DB
*.db
*.db-journal

# 로컬 DB 덤프 (pg_dump 결과 — 절대 커밋 금지)
*.dump

# IDE — 팀 공유 룰만 추적 (.cursor/rules)
.cursor/*
!.cursor/rules/
!.cursor/rules/**
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db
