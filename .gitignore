# Dependencies
node_modules/

# Environment (보안 - 절대 push 금지)
.env
.env.local
.env.*.local
.env.postgresql
server/.env.staging
**/.env.staging

# Build output
dist/
client/dist/
server/dist/
tools/soomgo-bridge/dist/
tools/soomgo-bridge/runtime/python/
tools/soomgo-bridge/**/__pycache__/

# 정적 의존성 사본 (postinstall 로 자동 생성됨 — pagedjs polyfill 등)
client/public/vendor/

# C/S 이미지 업로드 (로컬)
server/uploads/

# SQLite DB
*.db
*.db-journal

# 로컬 DB 덤프 (pg_dump 결과 — 절대 커밋 금지)
*.dump

# IDE — 팀 공유 룰만 추적 (.cursor/rules)
.cursor/*
!.cursor/rules/
!.cursor/rules/**
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Android 텔레CRM (apps/telecrm-android)
apps/telecrm-android/.gradle/
apps/telecrm-android/local.properties
apps/telecrm-android/**/build/
apps/telecrm-android/.idea/
apps/telecrm-android/*.iml
apps/telecrm-android/app/*.iml
apps/telecrm-android/.kotlin/

# 로컬 에이전트 — product/help 빌더 소스만 저장소 포함
/agent/*
!/agent/product/
/agent/product/node_modules/
/agent/product/output/assets/
malgun.ttf

# shared/ 는 TS 소스만 — server tsc 산출물 금지
shared/*.js
