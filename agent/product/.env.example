# ────────────────────────────────────────────────────────────────
# 청소비서 도움말 사이트 생성 에이전트 환경 설정
# 이 파일을 .env 로 복사하고 값을 채우세요.
# ────────────────────────────────────────────────────────────────

# 스테이징 서버 주소 (마지막 / 없이)
STAGING_BASE_URL=https://your-project.up.railway.app

# 업체 코드 (로그인 화면의 "업체 코드" 입력값 — 예: skcleanteck)
STAGING_TENANT_SLUG=skcleanteck

# 관리자 계정
STAGING_ADMIN_ID=admin
STAGING_ADMIN_PASSWORD=your-admin-password

# 팀장 계정 (팀장 화면 캡처용) — 이메일이 아닌 ID 방식
STAGING_TEAM_LOGIN_ID=kds
STAGING_TEAM_PASSWORD=your-team-password

# ────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY 는 필요 없습니다.
# 캡처 후 Claude Code(claude.ai/code)에게 스크린샷 설명을 요청하면
# 무료로 descriptions.json 을 생성할 수 있습니다.
# ────────────────────────────────────────────────────────────────
